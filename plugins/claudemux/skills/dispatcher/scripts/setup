#!/usr/bin/env bash
# setup — bind the claudemux plugin to a dispatcher directory on this machine.
#
# Run this from inside the directory you want to be the dispatcher's $DEV_DIR
# (the parent directory of all your sibling repos). Or pass --dev-dir <path>.
#
# What it does (idempotent):
#   1. Records $DEV_DIR in ~/.config/claudemux/config so `tm` can find it
#      regardless of where claudemux itself is installed.
#   2. Copies CLAUDE.md.template to $DEV_DIR/CLAUDE.md (unless one is present).
#   3. Creates /tmp/claude-idle/ so wait-idle has a place to write.
#   4. Prints next-step verification.
#
# What it does NOT do:
#   - Install a Stop hook. That ships with the plugin (hooks/hooks.json) and
#     follows the plugin's install/uninstall lifecycle.
#   - Start tmux, claude, or any teammate.
#   - Migrate any pre-existing AutoMemory; those files are personal state and
#     live under ~/.claude/projects/<cwd-sanitized>/memory/.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE="$SKILL_DIR/CLAUDE.md.template"
IDLE_DIR="/tmp/claude-idle"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/claudemux"
CONFIG_FILE="$CONFIG_DIR/config"

force=0
dev_dir_arg=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force) force=1; shift ;;
        --dev-dir) dev_dir_arg="${2:-}"; shift 2 ;;
        -h|--help)
            cat <<EOF
setup — install claudemux onto this machine.

Usage:
  $(basename "$0") [--dev-dir <path>] [--force]

Options:
  --dev-dir <path>  Use <path> as the dispatcher directory. Defaults to the
                    current working directory.
  --force           Overwrite <DEV_DIR>/CLAUDE.md even if it already exists.

Paths:
  config            $CONFIG_FILE
  template          $TEMPLATE
EOF
            exit 0 ;;
        *) echo "setup: unknown flag: $1" >&2; exit 1 ;;
    esac
done

DEV_DIR="${dev_dir_arg:-$PWD}"
[[ -d "$DEV_DIR" ]] || { echo "setup: dispatcher dir does not exist: $DEV_DIR" >&2; exit 1; }
DEV_DIR="$(cd "$DEV_DIR" && pwd)"
TARGET_CLAUDE_MD="$DEV_DIR/CLAUDE.md"

say() { echo "[setup] $*"; }

# --- 1. config (where tm looks up DEV_DIR) ---
mkdir -p "$CONFIG_DIR"
{
    echo "# Generated by claudemux setup on $(date -u +%FT%TZ)"
    echo "# Edit by hand if you move the dispatcher directory, or re-run setup."
    echo "DEV_DIR=\"$DEV_DIR\""
} > "$CONFIG_FILE"
say "wrote $CONFIG_FILE (DEV_DIR=$DEV_DIR)"

# --- 2. CLAUDE.md ---
if [[ ! -f "$TEMPLATE" ]]; then
    echo "setup: missing template at $TEMPLATE" >&2
    exit 1
fi

if [[ -f "$TARGET_CLAUDE_MD" && $force -eq 0 ]]; then
    if cmp -s "$TEMPLATE" "$TARGET_CLAUDE_MD"; then
        say "CLAUDE.md already matches template — skipping"
    else
        say "CLAUDE.md exists and differs from template — leaving in place (use --force to overwrite)"
        say "  diff: diff $TARGET_CLAUDE_MD $TEMPLATE"
    fi
else
    cp "$TEMPLATE" "$TARGET_CLAUDE_MD"
    say "wrote $TARGET_CLAUDE_MD from template"
fi

# --- 3. idle dir ---
mkdir -p "$IDLE_DIR"
say "ensured $IDLE_DIR exists"

# --- 4. report ---
cat <<EOF

[setup] done.

Verify:
  1. Start a tmux session and run \`claude\` in the dispatcher directory:
       tmux new-session -s dispatcher -c "$DEV_DIR"
       # then in the pane:
       claude
  2. In another shell, spawn a test teammate:
       "$SCRIPT_DIR/tm" spawn <repo>      # <repo> is a directory under $DEV_DIR
  3. Send a prompt, then wait-idle:
       "$SCRIPT_DIR/tm" send <repo> 'echo hello'
       "$SCRIPT_DIR/tm" wait-idle <repo> 60
     wait-idle should return "idle: <sid>" within a minute.

Tip — if you'd rather type \`tm\` directly, symlink it into your PATH:
    ln -s "$SCRIPT_DIR/tm" ~/.local/bin/tm   # ensure ~/.local/bin is in PATH

Notes:
  * The Stop hook touches /tmp/claude-idle/<sid> for every Claude Code session,
    including the dispatcher itself. That is intentional and harmless — no
    code waits on the dispatcher's own idle signal.
  * Per-user state files (AutoMemory, in-flight task ledger) live under
    ~/.claude/projects/<dev-dir-sanitized>/memory/ and are not managed here.
EOF
