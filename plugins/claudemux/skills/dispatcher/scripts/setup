#!/usr/bin/env bash
# setup — seed CLAUDE.md and the idle dir for a claudemux dispatcher.
#
# The "dispatcher directory" is wherever you run `claude` from to drive
# teammates; there is no global config that records its path. tm and the
# SessionStart hook both derive it at runtime ($PWD for tm; the cwd of
# each teammate session for the hook, by way of /tmp/teammate-*.cwd
# pointers that `tm spawn` writes). All this script does is seed the
# template CLAUDE.md and (legacy) clean up the stale config file from
# pre-Tier-3 installs.
#
# What it does (idempotent):
#   1. Copies CLAUDE.md.template to <dir>/CLAUDE.md (unless one is present).
#   2. Creates /tmp/claude-idle/ so wait-idle has a place to write.
#   3. Removes the legacy ~/.config/claudemux/config file if it exists
#      (no longer read; left in place would mislead future operators).
#   4. Prints next-step verification.
#
# What it does NOT do:
#   - Install hooks. Those ship with the plugin (hooks/hooks.json) and
#     follow the plugin's install/uninstall lifecycle.
#   - Start tmux, claude, or any teammate.
#   - Migrate any pre-existing AutoMemory; those files are personal state and
#     live under ~/.claude/projects/<cwd-sanitized>/memory/.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILL_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE="$SKILL_DIR/CLAUDE.md.template"
IDLE_DIR="/tmp/claude-idle"
LEGACY_CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/claudemux/config"

force=0
dev_dir_arg=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --force) force=1; shift ;;
        --dev-dir) dev_dir_arg="${2:-}"; shift 2 ;;
        -h|--help)
            cat <<EOF
setup — seed CLAUDE.md + idle dir for a claudemux dispatcher.

Usage:
  $(basename "$0") [--dev-dir <path>] [--force]

Options:
  --dev-dir <path>  Seed CLAUDE.md in <path>. Defaults to current working
                    directory. The runtime no longer records this path
                    anywhere — tm and the hooks derive it from cwd.
  --force           Overwrite <dir>/CLAUDE.md even if it already exists.

Paths:
  template          $TEMPLATE
EOF
            exit 0 ;;
        *) echo "setup: unknown flag: $1" >&2; exit 1 ;;
    esac
done

DISPATCHER_DIR="${dev_dir_arg:-$PWD}"
[[ -d "$DISPATCHER_DIR" ]] || { echo "setup: dispatcher dir does not exist: $DISPATCHER_DIR" >&2; exit 1; }
DISPATCHER_DIR="$(cd "$DISPATCHER_DIR" && pwd)"
TARGET_CLAUDE_MD="$DISPATCHER_DIR/CLAUDE.md"

say() { echo "[setup] $*"; }

# --- 1. legacy config cleanup ---
# Pre-Tier-3 setup wrote ~/.config/claudemux/config with a DEV_DIR= line.
# Nothing reads it anymore. Leaving it in place would suggest there's a
# bound dispatcher directory when there isn't.
if [[ -f "$LEGACY_CONFIG_FILE" ]]; then
    rm -f "$LEGACY_CONFIG_FILE"
    say "removed legacy $LEGACY_CONFIG_FILE (dispatcher dir is now derived from cwd)"
fi

# --- 2. CLAUDE.md ---
if [[ ! -f "$TEMPLATE" ]]; then
    echo "setup: missing template at $TEMPLATE" >&2
    exit 1
fi

if [[ -f "$TARGET_CLAUDE_MD" && $force -eq 0 ]]; then
    if cmp -s "$TEMPLATE" "$TARGET_CLAUDE_MD"; then
        say "CLAUDE.md already matches template — skipping"
    else
        say "CLAUDE.md exists and differs from template — leaving in place (use --force to overwrite)"
        say "  diff: diff $TARGET_CLAUDE_MD $TEMPLATE"
    fi
else
    cp "$TEMPLATE" "$TARGET_CLAUDE_MD"
    say "wrote $TARGET_CLAUDE_MD from template"
fi

# --- 3. idle dir ---
mkdir -p "$IDLE_DIR"
say "ensured $IDLE_DIR exists"

# --- 4. report ---
cat <<EOF

[setup] done.

Verify:
  1. Start a tmux session and run \`claude\` in the dispatcher directory:
       tmux new-session -s dispatcher -c "$DISPATCHER_DIR"
       # then in the pane:
       claude
  2. In another shell (or via the dispatcher's own Bash), spawn a teammate:
       tm spawn <repo>      # <repo> is a direct subdirectory of $DISPATCHER_DIR
  3. Send a prompt, then wait-idle:
       tm send <repo> 'echo hello'
       tm wait-idle <repo> 60
     wait-idle should return "idle: <sid>" within a minute.

Tip — \`tm\` is on Claude Code's PATH automatically (the plugin ships bin/tm
and Claude Code auto-adds each plugin's bin/ to PATH). \`tm spawn\` reads the
dispatcher dir from \`\$PWD\` at invocation time, so run it from inside the
dispatcher session (whose cwd is the dispatcher dir by construction).

Notes:
  * The Stop hook touches /tmp/claude-idle/<sid> for every Claude Code session,
    including the dispatcher itself. That is intentional and harmless — no
    code waits on the dispatcher's own idle signal.
  * Per-user state files (AutoMemory, in-flight task ledger) live under
    ~/.claude/projects/<cwd-sanitized>/memory/ and are not managed here.
EOF
