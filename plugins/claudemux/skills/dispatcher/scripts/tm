#!/usr/bin/env bash
# tm — tmux teammate manager for the dispatcher skill.
#
# Each "teammate" is a tmux session named `teammate-<repo>` running an
# interactive `claude` in `<current-dir>/<repo>`. There is NO configured
# "dispatcher directory" — tm uses $PWD as the parent of sibling repos.
# In practice, that means you run `tm spawn <repo>` from inside the
# dispatcher's own claude session (which has cwd == the parent of your
# sibling repos by construction). Running tm from anywhere else builds
# the wrong path and fails loudly with "repo not found".
#
# Why this script exists: the protocol for driving these teammates has a few
# non-obvious rules (most importantly, prompt text and Enter must be sent as
# two separate tmux send-keys calls, or the prompt silently fails to submit).
# Calling this script instead of raw tmux means every teammate is created and
# driven the same way, and the rules are in one place where a future fix lands
# for the entire system.
#
# Idle signaling is fully hook-driven by the claudemux plugin:
#   on-busy.sh        UserPromptSubmit / UserPromptExpansion / PreToolUse /
#                     PreCompact → touch /tmp/claude-idle/<sid>.busy
#   on-stop.sh        Stop / StopFailure / PostCompact / SessionEnd →
#                     rm <sid>.busy, write <sid>.last (Stop only), touch
#                     <sid> (the wait-idle marker)
#   on-session-start  SessionStart → iterate /tmp/teammate-*.cwd files,
#                     match the firing claude's cwd byte-exactly against
#                     one of them. On hit: update /tmp/teammate-<repo>.sid
#                     (handles /clear-induced sid rotation) AND touch
#                     /tmp/teammate-<repo>.ready (the spawn-readiness
#                     signal — `tm spawn` polls for this file instead of
#                     burning a fixed sleep).
# We avoid race-prone jsonl scanning by pre-generating a UUID at spawn time
# and handing it to `claude --session-id` directly — the jsonl filename then
# equals that UUID. The sid is stashed in /tmp/teammate-<repo>.sid so
# `tm wait-idle` / `tm last` / `tm states` know which files to read. `tm send`
# rm's the idle marker + .last + .busy first so a subsequent wait-idle / last
# / states reflects the NEW turn, not a stale one.

set -euo pipefail

PREFIX="teammate-"
IDLE_DIR="/tmp/claude-idle"

die() { echo "tm: $*" >&2; exit 1; }

# tmux `-t NAME` is a PREFIX match, so `has-session -t teammate-x` returns
# true when only `teammate-x-2` exists. We use two different exact-match
# tactics depending on the call's target context:
#
#   - Session-target calls (has-session, kill-session) take the `=NAME`
#     exact-match modifier. Keep these as `-t "=$name"`.
#
#   - Pane-target calls (send-keys, capture-pane, display-message) do
#     NOT accept `=NAME` (tmux 3.6+ rejects with "can't find pane: =NAME").
#     For these, resolve the session's INTERNAL id (e.g. `$4`) — that id
#     is byte-unambiguous — and pass it as the target.
#
# `resolve_pane_target <repo>` returns the internal `$N` for a teammate
# session by iterating list-sessions and matching the session name
# EXACTLY (awk `$2 == name`). At spawn time, prefer the `-P -F` trick on
# new-session so the id is returned without a second tmux call.
session_name() { echo "${PREFIX}$1"; }
resolve_pane_target() {
    local name; name=$(session_name "$1")
    tmux list-sessions -F '#{session_id} #{session_name}' 2>/dev/null \
        | awk -v n="$name" '$2 == n {print $1; exit}'
}
sid_file() { echo "/tmp/teammate-$1.sid"; }
send_at_file() { echo "/tmp/teammate-$1.send-at"; }
ready_file() { echo "/tmp/teammate-$1.ready"; }
cwd_file() { echo "/tmp/teammate-$1.cwd"; }

# Read the recorded sid for <repo>. Exits non-zero on miss (no sid file or
# empty), so cmd_send can tolerate "no sid yet" while wait-idle / last / kill
# use the _or_die variant for a uniform error story.
resolve_sid() {
    local sf; sf=$(sid_file "$1")
    [[ -s "$sf" ]] || return 1
    cat "$sf"
}

resolve_sid_or_die() {
    local repo="$1" sid
    sid=$(resolve_sid "$repo") || die "no sid file for $repo at $(sid_file "$repo") — was this teammate spawned via 'tm spawn'? (raw 'tmux new-session' won't seed the sid)"
    printf '%s' "$sid"
}

# Drop all hook artifacts for <sid> together — idle marker, last-turn
# text, and the busy marker — so a subsequent wait-idle / last / states
# sees the NEW turn, not a stale one. Used at spawn, send, and kill; the
# three paths must move in lockstep.
clear_idle() {
    [[ -n "${1:-}" ]] && rm -f "$IDLE_DIR/$1" "$IDLE_DIR/$1.last" "$IDLE_DIR/$1.busy"
}

# Format an absolute second-count as a short relative age (e.g. "12s", "3m", "2h").
fmt_age() {
    local age=$1
    if (( age < 60 )); then echo "${age}s"
    elif (( age < 3600 )); then echo "$((age/60))m"
    elif (( age < 86400 )); then echo "$((age/3600))h"
    else echo "$((age/86400))d"
    fi
}

# Detect whether the teammate is currently working. Pure hook-driven:
# the claudemux on-busy.sh hook touches /tmp/claude-idle/<sid>.busy on
# UserPromptSubmit / UserPromptExpansion / PreToolUse / PreCompact, and
# on-stop.sh removes it on Stop / StopFailure / PostCompact / SessionEnd.
# So the existence of <sid>.busy IS the BUSY signal — no pane scraping,
# no spinner regex, no v2.1.140+ "mid-tool with no spinner" blind spot.
#
# Returns 1 (not busy) if we have no sid for this repo yet, or if the
# .busy file doesn't exist.
#
# Known blind spots (intentional — these are not BUSY events as far as
# claude.ai is concerned, so they fire no hook):
#   - /help, /effort, /agents and other purely-TUI slash commands: the
#     teammate may be showing a dialog but reports BUSY=no
#   - permission prompts: claude is blocked waiting for y/n with no
#     hook fired (Notification event exists per docs but we don't bind
#     it — adding would let us flag this case, see SKILL.md)
pane_busy() {
    local repo="$1" sid
    sid=$(resolve_sid "$repo") || return 1
    [[ -f "$IDLE_DIR/$sid.busy" ]]
}

# Generate a lowercase UUID. macOS uuidgen emits uppercase; Claude Code
# normalizes session-ids to lowercase on disk (the jsonl filename is lowercase),
# so we normalize up front to keep the sid file and jsonl filename byte-equal.
new_sid() { uuidgen | tr '[:upper:]' '[:lower:]'; }

require_session() {
    local name; name=$(session_name "$1")
    tmux has-session -t "=$name" 2>/dev/null || die "no such teammate session: $name (try 'tm ls')"
    echo "$name"
}

cmd_ls() {
    # tmux ls returns non-zero when no server is running; mask it so pipefail
    # doesn't kill us. Empty output is the expected "no sessions" case.
    local rows=""
    rows=$( { tmux ls 2>/dev/null || true; } | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print $0}')
    if [[ -z "$rows" ]]; then
        echo "(no teammate sessions; use 'tm spawn <repo>')"
        return 0
    fi
    echo "$rows"
}

cmd_spawn() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm spawn <repo> [--resume <sid>]"
    shift

    local resume_sid=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume) resume_sid="${2:-}"; shift 2 ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    local path="$PWD/$repo"
    [[ -d "$path" ]] || die "repo not found at $path — tm spawn must run from the dispatcher directory (the parent of your sibling repos), and <repo> must be a direct subdirectory of it"

    # Normalize to the physical path. Claude Code emits cwd as the physical
    # path in hook payloads (macOS resolves /tmp → /private/tmp etc), so
    # writing the physical form to <repo>.cwd lets on-session-start.sh
    # byte-match without doing any normalization itself.
    local cwd_phys; cwd_phys=$(cd "$path" && pwd -P)

    local name; name=$(session_name "$repo")
    if tmux has-session -t "=$name" 2>/dev/null; then
        echo "$name already exists (use 'tm status $repo' to view, or 'tm kill $repo' first)"
        return 0
    fi

    # Clear the readiness signal BEFORE launching claude. The
    # SessionStart hook (on-session-start.sh) re-touches this file once
    # claude's REPL is up; the poll loop below blocks until it appears,
    # replacing the previous fixed "sleep 8".
    local rf; rf=$(ready_file "$repo")
    rm -f "$rf"

    # Record the teammate's physical cwd so the SessionStart hook can
    # identify "is the firing claude session this teammate?" by byte-exact
    # path match. Written BEFORE new-session so the .cwd file is in place
    # the moment the hook can possibly fire.
    echo "$cwd_phys" > "$(cwd_file "$repo")"

    # -P -F prints the new session's internal id (e.g. `$21`); we use it
    # as the pane-target for the subsequent send-keys so we don't rely on
    # name prefix-match resolution.
    local pane; pane=$(tmux new-session -d -s "$name" -c "$cwd_phys" -P -F '#{session_id}')
    local sid sf; sf=$(sid_file "$repo")
    if [[ -n "$resume_sid" ]]; then
        sid="$resume_sid"
        tmux send-keys -t "$pane" "claude --resume $sid" Enter
        echo "spawned: $name (cwd=$cwd_phys, resumed sid=$sid)"
    else
        # Pre-generate the UUID so the sid is known the moment spawn returns.
        # No more jsonl scanning, no race window: --session-id makes the jsonl
        # filename equal to this UUID, and the global Stop hook touches
        # /tmp/claude-idle/<that-same-uuid> on every turn-end.
        sid=$(new_sid)
        tmux send-keys -t "$pane" "claude --session-id $sid" Enter
        echo "spawned: $name (cwd=$cwd_phys, sid=$sid)"
    fi
    echo "$sid" > "$sf"
    clear_idle "$sid"

    # Poll for spawn readiness. The hook fires once the SessionStart
    # event reaches it; in practice that's within 2–4 s on a warm Mac,
    # so the 18 s cap (60 × 0.3 s) is generous. On timeout we surface a
    # warning but return successfully — callers can still try `tm send`
    # and will get a clear failure if claude really didn't come up.
    local i ready_after_ms=""
    for i in $(seq 1 60); do
        if [[ -f "$rf" ]]; then
            ready_after_ms=$(( i * 300 ))
            break
        fi
        sleep 0.3
    done
    if [[ -n "$ready_after_ms" ]]; then
        echo "ready: ${name} (SessionStart fired after ~${ready_after_ms} ms)"
    else
        echo "WARN: $name did not signal ready within 18s (no SessionStart hook fire — the plugin's on-session-start.sh may not be loaded, or claude failed to boot). Continuing; subsequent 'tm send' will fail loudly if the REPL is not up." >&2
    fi
}

cmd_status() {
    local repo="${1:-}"; local lines="${2:-80}"
    [[ -n "$repo" ]] || die "usage: tm status <repo> [lines=80]"
    require_session "$repo" >/dev/null
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"
    tmux capture-pane -t "$pane" -p -S "-${lines}"
}

cmd_send() {
    local repo="${1:-}"; shift || true
    [[ -n "$repo" && $# -gt 0 ]] || die "usage: tm send <repo> <prompt...>"
    local prompt="$*"
    local name; name=$(require_session "$repo")
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"

    # Clear the baseline idle + last-turn files so a subsequent wait-idle /
    # last reflects THIS prompt's outcome, not a previously satisfied turn.
    # No sid yet (raw tmux spawn) is tolerated — wait-idle would fail anyway.
    local sid=""
    sid=$(resolve_sid "$repo") && clear_idle "$sid" || true

    # Touch the send-at marker so wait-quiet has a "min time since action
    # started" to guard against the pane being momentarily quiet right after
    # send (before claude has rendered its spinner).
    : > "$(send_at_file "$repo")"

    # CRITICAL: prompt text and Enter must be two separate calls. Combining
    # them in one tmux send-keys inlines Enter as a newline inside the input
    # box and the prompt does not submit. -l (literal) avoids tmux interpreting
    # characters in the prompt as key names.
    tmux send-keys -t "$pane" -l "$prompt"
    tmux send-keys -t "$pane" Enter

    # Multi-line prompts need a SECOND Enter: once the input box contains
    # any newline, the first Enter is consumed as "insert newline at cursor"
    # and the second Enter (on the now-empty trailing line) actually submits.
    # Single-line prompts must NOT get a second Enter — that would submit
    # an empty follow-up turn. The gap defaults to 0.2s (empirically enough
    # for tmux to flush the literal text on a typical box); override via
    # TM_SEND_GAP if a loaded box or different terminal needs more.
    if [[ "$prompt" == *$'\n'* ]]; then
        sleep "${TM_SEND_GAP:-0.2}"
        tmux send-keys -t "$pane" Enter
    fi

    echo "sent to $name (Enter issued separately)"
    [[ -n "$sid" ]] && echo "sid=$sid"
}

cmd_wait_idle() {
    local repo="${1:-}"; local timeout="${2:-600}"
    [[ -n "$repo" ]] || die "usage: tm wait-idle <repo> [timeout=600]"
    require_session "$repo" >/dev/null
    local sid; sid=$(resolve_sid_or_die "$repo")

    local end; end=$(( $(date +%s) + timeout ))
    while [[ $(date +%s) -lt $end ]]; do
        if [[ -e "$IDLE_DIR/$sid" ]]; then
            echo "idle: $sid"
            if [[ -s "$IDLE_DIR/$sid.last" ]]; then
                echo "last: $IDLE_DIR/$sid.last ($(wc -c < "$IDLE_DIR/$sid.last" | tr -d ' ') bytes)"
            else
                echo "last: (no text reply this turn — assistant may have only used tools)"
            fi
            return 0
        fi
        sleep 3
    done
    echo "tm: timeout after ${timeout}s waiting for idle signal on $repo (sid=$sid)" >&2
    return 1
}

cmd_last() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm last <repo>"
    local sid; sid=$(resolve_sid_or_die "$repo")
    local lf="$IDLE_DIR/$sid.last"
    [[ -e "$lf" ]] || die "no last-turn file for $repo (sid=$sid) at $lf — has the teammate finished a turn yet? Try 'tm wait-idle $repo' first."
    cat "$lf"
}

cmd_kill() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm kill <repo>"
    local name; name=$(session_name "$repo")
    local sid=""
    sid=$(resolve_sid "$repo") && clear_idle "$sid" || true
    rm -f "$(sid_file "$repo")" "$(send_at_file "$repo")" "$(ready_file "$repo")" "$(cwd_file "$repo")"
    if tmux has-session -t "=$name" 2>/dev/null; then
        tmux kill-session -t "=$name"
        echo "killed: $name"
    else
        echo "not running: $name"
    fi
}

cmd_ask() {
    # One-shot send + wait + cat .last. Default uses wait-idle (Stop hook);
    # pass --quiet to use the pane-driven wait-quiet (for /compact and other
    # paths that don't fire a Stop event).
    local quiet=0 timeout=600 repo=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --quiet) quiet=1; shift ;;
            --timeout=*) timeout="${1#--timeout=}"; shift ;;
            --timeout) timeout="${2:-}"; shift 2 ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *) repo="$1"; shift; break ;;
        esac
    done
    [[ -n "$repo" && $# -gt 0 ]] || die "usage: tm ask [--quiet] [--timeout=N] <repo> <prompt...>"

    # cmd_send is chatty on stdout; route to stderr so only the reply lands
    # on our stdout (pipe-friendly: tm ask repo prompt | tee something).
    cmd_send "$repo" "$@" >&2

    local waiter_rc=0
    if (( quiet )); then
        cmd_wait_quiet "$repo" "$timeout" >&2 || waiter_rc=$?
    else
        cmd_wait_idle "$repo" "$timeout" >&2 || waiter_rc=$?
    fi

    local sid lf=""
    if sid=$(resolve_sid "$repo"); then
        lf="$IDLE_DIR/$sid.last"
    fi

    if (( waiter_rc != 0 )); then
        echo "tm ask: timed out after ${timeout}s on $repo" >&2
        # Best-effort partial: if Stop hook landed between our last poll and
        # here, dump .last as the "what we got". Empty stdout otherwise.
        [[ -n "$lf" && -s "$lf" ]] && cat "$lf"
        return 1
    fi

    # Success. --quiet may legitimately have no .last (e.g. /compact).
    [[ -n "$lf" && -s "$lf" ]] && cat "$lf"
    return 0
}

cmd_resume() {
    # Resume a prior conversation. The recommended call form is
    #     tm resume <repo> <sid>
    # with the sid pulled from the dispatcher's task ledger (each tracked
    # task records the sid of the teammate that owned it). When called
    # without a sid we fall back to "newest jsonl by mtime" as a one-off
    # convenience — that's NOT the typical workflow because the latest
    # jsonl is not necessarily the one you mean to continue.
    local repo="" sid="" prompt="" has_prompt=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --prompt) prompt="${2:-}"; has_prompt=1; shift 2 ;;
            --prompt=*) prompt="${1#--prompt=}"; has_prompt=1; shift ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *)
                if [[ -z "$repo" ]]; then repo="$1"
                elif [[ -z "$sid" ]]; then sid="$1"
                else die "tm resume: too many positional args (got '$1' after repo='$repo' sid='$sid')"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$repo" ]] || die "usage: tm resume <repo> [<sid>] [--prompt \"...\"]  (sid from ledger preferred; auto-pick on omit)"

    local path="$PWD/$repo"
    [[ -d "$path" ]] || die "repo not found at $path — tm resume must run from the dispatcher directory (the parent of your sibling repos)"
    # Use the physical path for Claude Code's project-dir encoding — that's
    # what it uses to derive the encoded directory name from cwd.
    local cwd_phys; cwd_phys=$(cd "$path" && pwd -P)

    local name; name=$(session_name "$repo")
    if tmux has-session -t "=$name" 2>/dev/null; then
        die "$name already running — 'tm kill $repo' first if you really want to start over"
    fi

    local encoded; encoded=$(printf '%s' "$cwd_phys" | tr / -)
    local project_dir="$HOME/.claude/projects/$encoded"

    if [[ -z "$sid" ]]; then
        # Auto-pick fallback. Warn so the caller notices the ledger lookup
        # was skipped — most resumes should target a specific task's sid.
        [[ -d "$project_dir" ]] || die "no project dir at $project_dir — has anyone ever run claude inside $path? Try 'tm spawn $repo' first."
        local latest
        latest=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -1)
        [[ -n "$latest" ]] || die "no .jsonl transcripts under $project_dir — try 'tm spawn $repo' to start fresh."
        sid=$(basename "$latest" .jsonl)
        echo "tm resume: no sid given — auto-picked $sid (jsonl mtime $(stat -f %Sm "$latest")). Prefer passing the sid from your task ledger." >&2
    else
        # Explicit sid: prove it exists as a jsonl under this repo's project
        # dir. Claude's --resume on an unknown sid produces a confusing
        # "session not found" deep inside the TUI; failing early here is
        # nicer.
        local target="$project_dir/$sid.jsonl"
        [[ -f "$target" ]] || die "no transcript at $target — wrong repo for this sid, or sid does not exist. Check 'ls $project_dir/'."
    fi

    [[ "$sid" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]] \
        || die "sid is not a valid uuid: $sid"

    cmd_spawn "$repo" --resume "$sid"

    if (( has_prompt )); then
        # Give the resumed claude a moment to render its banner / restore
        # state before sending. Empirically 3s is enough on a warm Mac.
        sleep 3
        cmd_send "$repo" "$prompt"
    fi
}

cmd_states() {
    local rows
    rows=$( { tmux ls 2>/dev/null || true; } | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print $1}')
    if [[ -z "$rows" ]]; then
        echo "(no teammate sessions)"
        return 0
    fi
    local now; now=$(date +%s)
    {
        printf 'REPO\tSID\tBUSY\tLAST\tPREVIEW\n'
        while IFS= read -r name; do
            local repo="${name#$PREFIX}"
            local sid sid_short busy last preview
            if sid=$(resolve_sid "$repo"); then
                sid_short="${sid:0:8}"
            else
                sid="" sid_short="?"
            fi
            if pane_busy "$repo"; then busy="yes"; else busy="no"; fi
            last="-"
            preview="-"
            if [[ -n "$sid" ]]; then
                local lf="$IDLE_DIR/$sid.last"
                if [[ -s "$lf" ]]; then
                    local sz lmt age
                    sz=$(wc -c < "$lf" | tr -d ' ')
                    lmt=$(stat -f %m "$lf" 2>/dev/null || echo 0)
                    age=$((now - lmt))
                    last="${sz}B/$(fmt_age "$age")"
                    # Sanitize the preview: strip control chars and tabs so
                    # column -t doesn't split a column, then cut to 50 bytes.
                    # macOS cut counts bytes, so multi-byte text may truncate
                    # mid-character — acceptable for a one-line preview.
                    preview=$(head -1 "$lf" | tr -d '\000-\037' | cut -c1-50)
                    [[ -z "$preview" ]] && preview="(no first line)"
                fi
            fi
            printf '%s\t%s\t%s\t%s\t%s\n' "$repo" "$sid_short" "$busy" "$last" "$preview"
        done <<< "$rows"
    } | column -t -s $'\t'
}

cmd_wait_quiet() {
    local repo="${1:-}"; local timeout="${2:-600}"
    [[ -n "$repo" ]] || die "usage: tm wait-quiet <repo> [timeout=600]"
    require_session "$repo" >/dev/null

    # send-at marker (touched by cmd_send) sets the floor for "time since
    # action started" — without it we'd return immediately when the pane was
    # already quiet from a prior turn.
    local send_at=0 sa
    sa=$(send_at_file "$repo")
    [[ -f "$sa" ]] && send_at=$(stat -f %m "$sa" 2>/dev/null || echo 0)

    local end; end=$(( $(date +%s) + timeout ))
    local quiet_streak=0
    while [[ $(date +%s) -lt $end ]]; do
        if pane_busy "$repo"; then
            quiet_streak=0
        else
            quiet_streak=$((quiet_streak + 1))
        fi
        local now; now=$(date +%s)
        # 2 consecutive quiet samples (~4s) plus 3s since send = ready.
        if (( quiet_streak >= 2 )) && (( now - send_at >= 3 )); then
            echo "quiet: $repo (pane has no spinner for $((quiet_streak * 2))s+)"
            return 0
        fi
        sleep 2
    done
    echo "tm: timeout after ${timeout}s waiting for quiet pane on $repo" >&2
    return 1
}

cmd_poll() {
    local repo="${1:-}"; local pattern="${2:-}"; local timeout="${3:-180}"
    [[ -n "$repo" && -n "$pattern" ]] || die "usage: tm poll <repo> <regex> [timeout=180]"
    require_session "$repo" >/dev/null
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"

    # Useful gotcha: do not poll for a string that appears verbatim in the
    # prompt you just sent — capture-pane will see the prompt echo and match
    # immediately. Match expected RESULT keywords instead (e.g. Scheduled,
    # Cancelled, ✓, error). For "wait until teammate is done", prefer
    # 'tm wait-idle' which uses the Stop-hook signal and doesn't need a regex.
    local end; end=$(( $(date +%s) + timeout ))
    while [[ $(date +%s) -lt $end ]]; do
        if tmux capture-pane -t "$pane" -p -S -300 2>/dev/null | grep -qE "$pattern"; then
            echo "matched: $pattern"
            return 0
        fi
        sleep 3
    done
    echo "tm: timeout after ${timeout}s waiting for /$pattern/ in $name" >&2
    return 1
}

cmd_help() {
    cat <<'EOF'
tm — tmux teammate manager for the dispatcher skill

USAGE
  tm ls
      list all teammate-<repo> sessions

  tm spawn <repo> [--resume <sid>]
      launch a claude teammate in $PWD/<repo>. tm must be run from the
      dispatcher directory (the parent of your sibling repos); fails with
      "repo not found" if invoked elsewhere. <repo> must be a direct
      subdirectory of $PWD (no nested paths).
      --resume <sid> picks up an existing session by jsonl-UUID; otherwise
      a fresh UUID is pre-generated and handed to `claude --session-id`,
      so 'tm wait-idle' works immediately without a prior 'tm send'.
      Blocks on /tmp/teammate-<repo>.ready (touched by the SessionStart
      hook once the REPL is up) for up to 18s before returning, so no
      ad-hoc sleep is needed before the first 'tm send'.

  tm status <repo> [lines=80]
      capture-pane the teammate's screen

  tm send <repo> <prompt...>
      send a prompt + Enter to the teammate (handles the dual-send).
      Also clears the idle-signal baseline (rm /tmp/claude-idle/<sid>) so a
      subsequent 'tm wait-idle' will wait for THIS prompt's completion,
      not a previously satisfied one. Do NOT roll your own with raw tmux
      send-keys, see notes inside the script.

  tm ask [--quiet] [--timeout=N] <repo> <prompt...>
      send + wait + cat .last in one shot. The dispatcher's "round-trip"
      shorthand: prompt goes to the teammate, this blocks until the reply
      is available, and the assistant text is printed to stdout (pipe-
      friendly — diagnostics go to stderr). Default uses wait-idle; pass
      --quiet to use wait-quiet (for /compact and other non-turn-end paths).
      Default timeout 600s. On timeout, prints partial .last to stdout
      (if Stop hook landed in the race window) and exits non-zero.

  tm resume <repo> [<sid>] [--prompt "..."]
      Resume a prior conversation. PREFER passing the sid explicitly — the
      dispatcher's task ledger (active-dispatcher-tasks.md) records the sid
      of each teammate it spawned; pull from there. With sid given, this is
      equivalent to 'tm spawn <repo> --resume <sid>' but with an up-front
      check that the jsonl exists in the right project dir.
      Without sid: auto-pick the newest jsonl by mtime as a one-off
      convenience (warns on stderr so you notice the ledger was skipped).
      Fails if a teammate session for <repo> already exists.
      Optional --prompt sends a follow-up message after the resumed banner
      renders.

  tm wait-idle <repo> [timeout=600]
      block until the teammate's Stop hook fires (file appears at
      /tmp/claude-idle/<sid>). On hit, also reports the path of the
      <sid>.last file (the assistant's last-turn text, written by the
      same hook). Requires the plugin's Stop hook to be loaded — it
      writes both files every time a session ends a turn.

  tm last <repo>
      cat the assistant's last-turn text for <repo>, captured by the
      Stop hook into /tmp/claude-idle/<sid>.last. Use this instead of
      'tm status' when you need the full reply — tmux scrollback truncates,
      but the .last file is the complete text the assistant emitted.

  tm kill <repo>
      kill the teammate session and clean up its sid/idle/send-at files

  tm states
      one-line summary per teammate: REPO, SID (first 8 chars), BUSY (yes if
      the pane shows a working spinner), LAST (size + age of <sid>.last from
      the Stop hook), PREVIEW (first 50 chars of <sid>.last). Use this when
      you want to know what every teammate is doing at a glance.

  tm wait-quiet <repo> [timeout=600]
      block until the teammate's pane shows no working spinner for ~4
      consecutive seconds AND at least 3s have passed since the last 'tm send'.
      Sister to 'wait-idle' but pane-driven, so it also catches non-turn-end
      operations like /compact and /clear (which do NOT trigger the Stop hook).
      Known blind spot: a permission prompt blocks claude with no spinner —
      wait-quiet will return "ready" but the teammate is actually waiting for
      a y/n decision; 'tm status' shows the prompt.

  tm poll <repo> <regex> [timeout=180]
      block until pane content matches a regex; for "wait until done"
      prefer 'tm wait-idle' — keep this for cases where the idle hook
      can't catch an interesting intermediate state. Pattern should match
      the EXPECTED RESULT, not the prompt you just sent.

ENVIRONMENT
  (none — tm derives the dispatcher directory from $PWD at invocation
  time, with no global config file or env override. To "switch" dispatcher
  trees, cd to the other tree and run tm there.)
EOF
}

main() {
    local sub="${1:-help}"
    shift || true
    case "$sub" in
        ls)         cmd_ls "$@" ;;
        spawn)      cmd_spawn "$@" ;;
        status)     cmd_status "$@" ;;
        send)       cmd_send "$@" ;;
        ask)        cmd_ask "$@" ;;
        resume)     cmd_resume "$@" ;;
        wait-idle)  cmd_wait_idle "$@" ;;
        last)       cmd_last "$@" ;;
        kill)       cmd_kill "$@" ;;
        states)     cmd_states "$@" ;;
        wait-quiet) cmd_wait_quiet "$@" ;;
        poll)       cmd_poll "$@" ;;
        help|-h|--help) cmd_help ;;
        *) echo "tm: unknown subcommand: $sub" >&2; cmd_help; exit 1 ;;
    esac
}

main "$@"
