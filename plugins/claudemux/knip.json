{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/main.ts",
    "test/**/*.test.ts",
    "test/integration/**/*.itest.ts",
    "vitest.integration.config.ts",
    "resolver-register.mjs",
    "resolver.mjs"
  ],
  "project": [
    "src/**/*.ts",
    "test/**/*.ts",
    "!src/codex-protocol/**",
    "!third_party/**"
  ],
  "include": ["files", "exports", "types"],
  "ignoreExportsUsedInFile": true
}
