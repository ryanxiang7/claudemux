#!/usr/bin/env bash
# tm — the dispatcher's CLI: tmux teammate manager, plus task-ledger and
# context-usage helpers for dispatcher bookkeeping.
#
# This is a thin Node launcher. On the 1.0 (`next`) line the orchestrator is
# a TypeScript codebase under `../core/`, bundled at release time with
# esbuild into `../core/dist/cli.mjs` (a single self-contained ES module
# with no runtime npm dependencies). This launcher just locates that bundle
# and execs Node against it; help text, verb dispatch, and tmux/state
# orchestration all live in the bundle.
#
# Production install path: a marketplace install of the claudemux plugin
# does *not* run `npm install`, so the bundle is committed to the repo and
# the launcher needs only `node` on PATH. `npm run build` in
# `plugins/claudemux/core/` re-emits the bundle from current source; CI
# rebuilds and asserts `git diff --exit-code dist/` so a stale bundle
# never lands.

set -eu

# Follow the script's own symlink chain. BSD `readlink` (macOS) has no `-f`,
# so we loop manually — necessary when a user symlinks this launcher into
# their PATH (`ln -s .../plugins/claudemux/bin/tm ~/.local/bin/tm`): a plain
# `dirname "$0"` resolves to the symlink's directory, not the real script's,
# and the relative `../core/dist/cli.mjs` lookup misses.
SCRIPT="$0"
while [[ -L "$SCRIPT" ]]; do
    LINK_DIR="$(cd "$(dirname "$SCRIPT")" && pwd -P)"
    LINK_TARGET="$(readlink "$SCRIPT")"
    if [[ "$LINK_TARGET" = /* ]]; then
        SCRIPT="$LINK_TARGET"
    else
        SCRIPT="$LINK_DIR/$LINK_TARGET"
    fi
done
HERE="$(cd "$(dirname "$SCRIPT")" && pwd -P)"
BUNDLE="$HERE/../core/dist/cli.mjs"

if ! command -v node >/dev/null 2>&1; then
    echo "tm: node not found on PATH. Install Node 22+ (https://nodejs.org/) and try again." >&2
    exit 1
fi

if [[ ! -f "$BUNDLE" ]]; then
    echo "tm: bundle missing at $BUNDLE. Run 'npm run build' in plugins/claudemux/core/ (or reinstall the plugin)." >&2
    exit 1
fi

exec node "$BUNDLE" "$@"
