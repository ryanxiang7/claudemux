#!/usr/bin/env bash
# tm — the dispatcher's CLI: tmux teammate manager, plus task-ledger and
# context-usage helpers for dispatcher bookkeeping.
#
# Each "teammate" is a tmux session named `teammate-<repo>` running an
# interactive `claude` in `<dispatcher-dir>/<repo>`. The dispatcher
# directory is resolved as `${TM_DISPATCHER_DIR:-$PWD}` once at script
# start — set TM_DISPATCHER_DIR (typically via the dispatcher's
# .claude/settings.json `env` block, which scripts/setup.sh writes on
# first run) so dispatcher work is immune to Bash-tool cwd drift; the
# $PWD fallback preserves backward compatibility for dispatchers set up
# before this feature. Running tm from outside the dispatcher tree (and
# without the env set) builds the wrong path and fails with
# "repo not found".
#
# Why this script exists: the protocol for driving these teammates has a few
# non-obvious rules (most importantly, prompt text and Enter must be sent as
# two separate tmux send-keys calls, or the prompt silently fails to submit).
# Calling this script instead of raw tmux means every teammate is created and
# driven the same way, and the rules are in one place where a future fix lands
# for the entire system.
#
# Idle signaling is fully hook-driven by the claudemux plugin:
#   on-busy.sh        UserPromptSubmit / UserPromptExpansion / PreToolUse /
#                     PreCompact → touch /tmp/claude-idle/<sid>.busy
#   on-stop.sh        Stop / StopFailure / PostCompact / SessionEnd →
#                     rm <sid>.busy, write <sid>.last (Stop only), touch
#                     <sid> (the idle marker that 'tm wait' and the wait
#                     phase of 'tm send' / 'tm compact' / 'tm spawn
#                     --prompt' all block on)
#   on-session-start  SessionStart → require $CLAUDEMUX_TEAMMATE_REPO (set
#                     by `tm spawn` via `tmux new-session -e`); without
#                     it, no-op. Then byte-match the firing claude's cwd
#                     against /tmp/teammate-<repo>.cwd, AND require the
#                     env's repo equal the matched repo. On hit: update
#                     /tmp/teammate-<repo>.sid (handles /clear-induced
#                     sid rotation) AND touch /tmp/teammate-<repo>.ready
#                     (the spawn-readiness signal — `tm spawn` polls for
#                     this file instead of burning a fixed sleep). The
#                     env gate is what prevents a dispatcher whose cwd
#                     happens to equal a recorded teammate.cwd from
#                     hijacking the teammate's sid file.
# We avoid race-prone jsonl scanning by pre-generating a UUID at spawn time
# and handing it to `claude --session-id` directly — the jsonl filename then
# equals that UUID. The sid is stashed in /tmp/teammate-<repo>.sid so
# `tm wait` / `tm last` / `tm states` know which files to read. `tm send`
# rm's the idle marker + .last + .busy first so a subsequent wait phase
# reflects the NEW turn, not a stale one.

set -euo pipefail

PREFIX="teammate-"
IDLE_DIR="/tmp/claude-idle"

# Resolved-once dispatcher directory: env override first, $PWD fallback
# for backward compat. Every "the parent of sibling repos" reference in
# this script should consult $DISPATCHER_DIR, not $PWD directly — that's
# what makes tm immune to Bash-tool cwd drift once setup.sh has written
# TM_DISPATCHER_DIR into the dispatcher's .claude/settings.json.
# `tm doctor` reports whether the env was actually present.
DISPATCHER_DIR="${TM_DISPATCHER_DIR:-$PWD}"

die() { echo "tm: $*" >&2; exit 1; }

# Common "<repo> not under <dispatcher-dir>" failure path for spawn /
# resume. If the dispatcher dir is itself a git working tree, the user
# almost certainly pointed tm at the wrong directory (e.g. inside a
# working repo instead of the parent of sibling repos — common when the
# dispatcher cwd happens to be a maintained plugin/repo, or when
# TM_DISPATCHER_DIR was set to a single repo). Steer them to cd up;
# otherwise fall back to the generic "repo not found" message.
die_repo_not_found() {
    local verb="$1" repo="$2" path="$3"
    if [[ -d "$DISPATCHER_DIR/.git" ]]; then
        die "$DISPATCHER_DIR looks like a git working tree (.git exists), not a dispatcher root.
    The dispatcher dir should be the PARENT of your sibling repos.
    Try:  cd \"$(dirname "$DISPATCHER_DIR")\" && tm $verb $repo
    (Or set TM_DISPATCHER_DIR in your dispatcher's .claude/settings.json
    — run /claudemux:setup to wire it up automatically.)"
    fi
    die "repo not found at $path — <repo> must be a direct subdirectory of the dispatcher dir ($DISPATCHER_DIR). Dispatcher dir is read from TM_DISPATCHER_DIR (env) or \$PWD; if it's wrong, set TM_DISPATCHER_DIR or run tm from the right place."
}

# tmux `-t NAME` is a PREFIX match, so `has-session -t teammate-x` returns
# true when only `teammate-x-2` exists. We use two different exact-match
# tactics depending on the call's target context:
#
#   - Session-target calls (has-session, kill-session) take the `=NAME`
#     exact-match modifier. Keep these as `-t "=$name"`.
#
#   - Pane-target calls (send-keys, capture-pane, display-message) do
#     NOT accept `=NAME` (tmux 3.6+ rejects with "can't find pane: =NAME").
#     For these, resolve the session's INTERNAL id (e.g. `$4`) — that id
#     is byte-unambiguous — and pass it as the target.
#
# `resolve_pane_target <repo>` returns the internal `$N` for a teammate
# session by iterating list-sessions and matching the session name
# EXACTLY (awk `$2 == name`). At spawn time, prefer the `-P -F` trick on
# new-session so the id is returned without a second tmux call.
session_name() { echo "${PREFIX}$1"; }
resolve_pane_target() {
    local name; name=$(session_name "$1")
    tmux list-sessions -F '#{session_id} #{session_name}' 2>/dev/null \
        | awk -v n="$name" '$2 == n {print $1; exit}'
}
sid_file() { echo "/tmp/teammate-$1.sid"; }
send_at_file() { echo "/tmp/teammate-$1.send-at"; }
ready_file() { echo "/tmp/teammate-$1.ready"; }
cwd_file() { echo "/tmp/teammate-$1.cwd"; }

# Encode a filesystem path into Claude Code's project-dir address and
# return the absolute "$HOME/.claude/projects/<encoded>" path.
#
# Claude Code derives the project-dir name from the claude process's
# cwd by replacing every '/' and '.' with '-'. This helper is the ONE
# source of truth for that encoding — every site that needs to locate
# a Claude project dir on disk must go through it, otherwise the same
# repo can end up addressed by two different strings (already happened
# once: a `tr / -` call site silently dropped '.' from paths containing
# a dot, e.g. ~/Development/foo.bar/repo).
encode_project_dir() {
    local encoded; encoded=$(printf '%s' "$1" | tr './' '-')
    printf '%s/.claude/projects/%s' "$HOME" "$encoded"
}

# Resolve a teammate <repo> to its Claude Code project dir, using the
# physical path (cd + pwd -P) so symlinked dispatcher trees still
# match what claude wrote on disk. Returns 1 if the repo subdirectory
# does not exist under the dispatcher dir.
project_dir_for_repo() {
    local path="$DISPATCHER_DIR/$1"
    [[ -d "$path" ]] || return 1
    local cwd_phys; cwd_phys=$(cd "$path" && pwd -P)
    encode_project_dir "$cwd_phys"
}

# Resolve the dispatcher's own AutoMemory directory — the project dir
# for the dispatcher's claude cwd ($DISPATCHER_DIR), with /memory appended.
memory_dir() {
    printf '%s/memory' "$(encode_project_dir "$DISPATCHER_DIR")"
}

# Normalize a task slug for use as part of a claude `--name` value. ASCII
# lowercase plus CJK Unified Ideographs (U+4E00–U+9FFF, e.g. 国际化 / 日本語)
# are kept verbatim; every other character (punctuation, whitespace, hiragana,
# katakana, hangul, emoji, ...) collapses into a single '-' separator.
# Leading/trailing '-' are stripped and the result is capped at 30 characters
# (counted as Unicode code points, not bytes). Empty result means the input
# had no usable allowlist characters — caller should reject.
sanitize_task_slug() {
    printf '%s' "$1" | perl -CSDA -e '
        local $/;
        my $s = <STDIN>;
        $s = "" unless defined $s;
        $s =~ tr/A-Z/a-z/;
        $s =~ s/[^a-z0-9\x{4e00}-\x{9fff}]+/-/g;
        $s =~ s/^-+//; $s =~ s/-+$//;
        if (length($s) > 30) {
            $s = substr($s, 0, 30);
            $s =~ s/-+$//;
        }
        print $s;
    '
}

# 4 random [a-z0-9] chars — the suffix for an auto-named teammate session.
# 36^4 = ~1.7M; the per-repo prefix already disambiguates, so 4 is plenty.
rand_suffix() {
    LC_ALL=C tr -dc 'a-z0-9' < /dev/urandom 2>/dev/null | head -c 4 || true
}

# Read the recorded sid for <repo>. Exits non-zero on miss (no sid file or
# empty), so cmd_send can tolerate "no sid yet" while wait / last / kill
# use the _or_die variant for a uniform error story.
resolve_sid() {
    local sf; sf=$(sid_file "$1")
    [[ -s "$sf" ]] || return 1
    cat "$sf"
}

resolve_sid_or_die() {
    local repo="$1" sid
    sid=$(resolve_sid "$repo") || die "no sid file for $repo at $(sid_file "$repo") — was this teammate spawned via 'tm spawn'? (raw 'tmux new-session' won't seed the sid)"
    printf '%s' "$sid"
}

# Drop all hook artifacts for <sid> together — idle marker, last-turn
# text, and the busy marker — so a subsequent wait / last / states sees
# the NEW turn, not a stale one. Used at spawn, send, and kill; the
# three paths must move in lockstep.
clear_idle() {
    [[ -n "${1:-}" ]] && rm -f "$IDLE_DIR/$1" "$IDLE_DIR/$1.last" "$IDLE_DIR/$1.busy"
}

# Format an absolute second-count as a short relative age (e.g. "12s", "3m", "2h").
fmt_age() {
    local age=$1
    if (( age < 60 )); then echo "${age}s"
    elif (( age < 3600 )); then echo "$((age/60))m"
    elif (( age < 86400 )); then echo "$((age/3600))h"
    else echo "$((age/86400))d"
    fi
}

# Format a file's byte size as a short human string (e.g. "84K", "2.4M").
fmt_size() {
    local b
    b=$(stat -f %z "$1" 2>/dev/null || echo 0)
    awk -v b="$b" 'BEGIN {
        if      (b < 1024)        printf "%dB",   b
        else if (b < 1048576)     printf "%dK",   b/1024
        else if (b < 1073741824)  printf "%.1fM", b/1048576
        else                      printf "%.1fG", b/1073741824
    }'
}

# Detect whether the teammate is currently working. Pure hook-driven:
# the claudemux on-busy.sh hook touches /tmp/claude-idle/<sid>.busy on
# UserPromptSubmit / UserPromptExpansion / PreToolUse / PreCompact, and
# on-stop.sh removes it on Stop / StopFailure / PostCompact / SessionEnd.
# So the existence of <sid>.busy IS the BUSY signal — no pane scraping,
# no spinner regex, no v2.1.140+ "mid-tool with no spinner" blind spot.
#
# Returns 1 (not busy) if we have no sid for this repo yet, or if the
# .busy file doesn't exist.
#
# Known blind spots (intentional — these are not BUSY events as far as
# claude.ai is concerned, so they fire no hook):
#   - /help, /effort, /agents and other purely-TUI slash commands: the
#     teammate may be showing a dialog but reports BUSY=no
#   - permission prompts: claude is blocked waiting for y/n with no
#     hook fired (Notification event exists per docs but we don't bind
#     it — adding would let us flag this case, see SKILL.md)
pane_busy() {
    local repo="$1" sid
    sid=$(resolve_sid "$repo") || return 1
    [[ -f "$IDLE_DIR/$sid.busy" ]]
}

# Generate a lowercase UUID. macOS uuidgen emits uppercase; Claude Code
# normalizes session-ids to lowercase on disk (the jsonl filename is lowercase),
# so we normalize up front to keep the sid file and jsonl filename byte-equal.
new_sid() { uuidgen | tr '[:upper:]' '[:lower:]'; }

require_session() {
    # Output convention (load-bearing across this script): "$repo (tmux=$name)"
    # — bare handle is what every tm verb accepts; the tmux name is shown only
    # as a parenthesized debug hint. If you tweak the format here, sweep every
    # other site that emits it (spawn / kill / sent-to).
    local repo="$1" name
    name=$(session_name "$repo")
    tmux has-session -t "=$name" 2>/dev/null || die "no such teammate session: $repo (tmux=$name; try 'tm ls')"
    echo "$name"
}

# Enumerate every running teammate's short repo name. Used by --all
# fan-out commands. Source of truth is tmux (a stale sid file without
# a live session doesn't count).
iter_repos() {
    { tmux ls 2>/dev/null || true; } \
        | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print substr($1, length(p)+1)}'
}

# --- shared helpers used by send / wait / compact / spawn --prompt ---
#
# These factor out the three building blocks the atomic verbs share:
#   1) push prompt + Enter into the teammate's pane (dual-send protocol),
#   2) block on the Stop-hook idle marker,
#   3) print the captured .last text — or a sentinel line when no text
#      was emitted (tool-only turn, /compact, /clear).
# The user-facing verbs (cmd_send, cmd_wait, cmd_compact) compose these
# instead of each carrying its own copy of the polling + cat ritual.

# Send a prompt into <repo>'s pane. NO wait, NO output beyond stderr
# "sent" note. Clears the idle/.last/.busy baseline first so a subsequent
# wait reflects THIS turn, not a prior one, and touches send-at for
# pane-quiet's "min time since action" guard.
#
# Two delivery modes by size:
#
#   * Short single-line prompts (<= TM_SEND_INLINE_MAX, default 200 chars,
#     no embedded newline): use `send-keys -l` then one Enter. Fast path
#     for slash commands (/compact, /clear) and one-liners; no paste
#     ceremony needed because the data fits in one PTY write.
#
#   * Larger or multi-line prompts: stage the prompt in a named tmux
#     buffer and use `paste-buffer -p -r` so the bytes arrive wrapped
#     in a single bracketed-paste sequence (\e[200~ ... \e[201~) with
#     embedded LFs preserved (without -r, tmux rewrites LF -> CR).
#     Claude Code's TUI groups everything inside the brackets into one
#     "[Pasted text #1]" chip, and the Enter that follows lands AFTER
#     the \e[201~ end-marker, so the TUI processes it as submit rather
#     than as "append a newline inside the pending paste".
#
#     Without the brackets, the TUI guesses whether incoming chars are
#     a paste by inter-character timing. tmux's `-l` write can fragment
#     across multiple PTY writes for large prompts, which the TUI sees
#     as several separate pastes ("[Pasted text #1][Pasted text #2]…")
#     with the trailing Enter buried inside one of them, so the prompt
#     just sits in the input box and never submits.
#
#     After the paste the helper sleeps long enough for the TUI to
#     finish rendering the chip before sending Enter; the delay scales
#     with prompt size and can be overridden with TM_SEND_GAP=<seconds>
#     (the override is validated up front — a malformed value would
#     otherwise crash `sleep` mid-flow under `set -e` and strand the
#     prompt inside the input box, which is the exact failure mode
#     this function exists to fix).
_send_keys() {
    local repo="$1" prompt="$2"
    local name; name=$(require_session "$repo")
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"

    local sid=""
    if sid=$(resolve_sid "$repo"); then
        clear_idle "$sid" || true
    fi
    : > "$(send_at_file "$repo")"

    local n=${#prompt}
    local inline_max="${TM_SEND_INLINE_MAX:-200}"
    [[ "$inline_max" =~ ^[0-9]+$ ]] \
        || die "TM_SEND_INLINE_MAX must be a non-negative integer (got: '$inline_max')"

    if (( n <= inline_max )) && [[ "$prompt" != *$'\n'* ]]; then
        tmux send-keys -t "$pane" -l "$prompt"
        tmux send-keys -t "$pane" Enter
    else
        local default_gap
        if   (( n <=   256 )); then default_gap="0.2"
        elif (( n <=  1024 )); then default_gap="0.5"
        elif (( n <=  4096 )); then default_gap="1.0"
        elif (( n <= 16384 )); then default_gap="2.0"
        else                        default_gap="4.0"
        fi
        local gap="${TM_SEND_GAP:-$default_gap}"
        [[ "$gap" =~ ^[0-9]+(\.[0-9]+)?$ ]] \
            || die "TM_SEND_GAP must be a non-negative number of seconds (got: '$gap')"

        local buf="tm-send-$$-$RANDOM"
        # Cleanup trap covers the paste-buffer-failed-after-load-buffer-succeeded
        # case: -d only deletes on a successful paste, and named buffers are
        # exempt from tmux's auto-eviction, so without this each failed send
        # would leak an entry into `tmux list-buffers`. The delete-buffer call
        # is a no-op once `paste-buffer -d` ran cleanly. $buf is baked in at
        # trap-set time (double-quoted) because RETURN runs in the caller's
        # scope where the `local` would otherwise be unbound under `set -u`.
        # printf '%s' avoids the trailing newline that here-strings add, so the
        # paste content is exactly the prompt text byte-for-byte.
        # shellcheck disable=SC2064  # $buf expansion at trap-set time is intentional (see comment above)
        trap "tmux delete-buffer -b '$buf' 2>/dev/null || true" RETURN
        printf '%s' "$prompt" | tmux load-buffer -b "$buf" -
        tmux paste-buffer -p -r -d -b "$buf" -t "$pane"

        sleep "$gap"
        tmux send-keys -t "$pane" Enter
    fi

    echo "sent to $repo (tmux=$name)" >&2
    [[ -n "$sid" ]] && echo "sid=$sid" >&2
    return 0
}

# Block until /tmp/claude-idle/<sid> exists (the Stop-hook idle marker),
# or until <timeout> seconds elapse. No output on success — that's the
# caller's job. Returns 0 on hit, 1 on timeout.
_wait_idle_signal() {
    local repo="$1" timeout="${2:-600}" fresh="${3:-0}"
    require_session "$repo" >/dev/null
    local sid; sid=$(resolve_sid_or_die "$repo")
    (( fresh )) && clear_idle "$sid"

    local end; end=$(( $(date +%s) + timeout ))
    while [[ $(date +%s) -lt $end ]]; do
        [[ -e "$IDLE_DIR/$sid" ]] && return 0
        sleep 3
    done
    return 1
}

# Block until the teammate's pane has shown no working spinner for ~4s
# AND at least 3s have passed since the last send. Used by --pane-quiet
# paths where no hook will fire — TUI-only commands like /help, /effort,
# /agents, and permission prompts. Returns 0 on hit, 1 on timeout.
_wait_pane_quiet() {
    local repo="$1" timeout="${2:-600}"
    require_session "$repo" >/dev/null

    local send_at=0 sa
    sa=$(send_at_file "$repo")
    [[ -f "$sa" ]] && send_at=$(stat -f %m "$sa" 2>/dev/null || echo 0)

    local end; end=$(( $(date +%s) + timeout ))
    local quiet_streak=0
    while [[ $(date +%s) -lt $end ]]; do
        if pane_busy "$repo"; then
            quiet_streak=0
        else
            quiet_streak=$((quiet_streak + 1))
        fi
        local now; now=$(date +%s)
        if (( quiet_streak >= 2 )) && (( now - send_at >= 3 )); then
            return 0
        fi
        sleep 2
    done
    return 1
}

# Print the assistant's last-turn text for <repo> to stdout. If .last is
# missing or empty — tool-only turn, /compact, /clear, or fresh spawn
# with the empty-sentinel — emit a single explanatory line so dispatcher
# stdout is never silently empty when the verb succeeded.
_print_last_or_empty() {
    local repo="$1" sid
    sid=$(resolve_sid "$repo") || { echo "(no sid for $repo)"; return 0; }
    local lf="$IDLE_DIR/$sid.last"
    if [[ -s "$lf" ]]; then
        cat "$lf"
    else
        echo "(no text reply this turn — tool-only, /compact, /clear, or fresh spawn)"
    fi
}

# Echo current ctx for <repo> on stderr after a Stop-waiting verb returns.
# Same number as 'tm ctx <repo>', minus the repo prefix. Lets the
# dispatcher consume the post-turn ctx inline with the reply instead of
# making a separate 'tm ctx' call after every send/wait — that pattern
# accounted for a noticeable share of post-Stop activity in the 0.3.0
# usage data.
#
# Soft-fail by design: if the jsonl can't be read or has no assistant
# usage entry yet, stay silent. The reply has already shipped on stdout
# and a stderr error line would only add noise. Skip entirely on
# --pane-quiet paths (TUI-only commands produce no assistant turn, so
# the printed number would be stale).
_echo_ctx_to_stderr() {
    local repo="$1"
    local body
    if body=$(_ctx_format_line "$repo" 2>/dev/null); then
        echo "ctx: $body" >&2
    fi
}

cmd_ls() {
    # tmux ls returns non-zero when no server is running; mask it so pipefail
    # doesn't kill us. Empty output is the expected "no sessions" case.
    local rows=""
    rows=$( { tmux ls 2>/dev/null || true; } | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print $0}')
    if [[ -z "$rows" ]]; then
        echo "(no teammate sessions; use 'tm spawn <repo>')"
        return 0
    fi
    echo "$rows"
}

cmd_spawn() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm spawn <repo> [--task <slug>] [--prompt \"...\"] [--no-wait]"
    shift

    # --resume <sid> is intentionally undocumented: it is the implementation
    # detail by which cmd_resume reuses spawn's launch logic. User-facing
    # resume goes through 'tm resume', which validates the jsonl exists,
    # checks UUID format, and supports auto-pick. Direct callers should not
    # rely on this flag.
    local resume_sid="" task="" prompt="" has_prompt=0 no_wait=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --resume)   resume_sid="${2:-}"; shift 2 ;;
            --task)     task="${2:-}"; shift 2 ;;
            --task=*)   task="${1#--task=}"; shift ;;
            --prompt)   [[ $# -ge 2 ]] || die "tm spawn: --prompt requires a value"
                        prompt="$2"; has_prompt=1; shift 2 ;;
            --prompt=*) prompt="${1#--prompt=}"; has_prompt=1; shift ;;
            --no-wait)  no_wait=1; shift ;;
            *) die "unknown flag: $1" ;;
        esac
    done

    if (( no_wait )) && ! (( has_prompt )); then
        die "tm spawn: --no-wait is only valid with --prompt (a fresh spawn without a prompt already returns as soon as the REPL is ready)"
    fi

    local path="$DISPATCHER_DIR/$repo"
    [[ -d "$path" ]] || die_repo_not_found spawn "$repo" "$path"

    # Normalize to the physical path. Claude Code emits cwd as the physical
    # path in hook payloads (macOS resolves /tmp → /private/tmp etc), so
    # writing the physical form to <repo>.cwd lets on-session-start.sh
    # byte-match without doing any normalization itself.
    local cwd_phys; cwd_phys=$(cd "$path" && pwd -P)

    # The dispatcher directory is on every teammate's upward CLAUDE.md
    # walk, so without this Claude Code loads the dispatcher's own
    # CLAUDE.md/CLAUDE.local.md as teammate "project instructions".
    # Inject claudeMdExcludes via --settings (the flagSettings tier,
    # merged before the memory walk runs) so the teammate skips exactly
    # those two files but still loads the target repo's own CLAUDE.md.
    # The flag rides only on the teammate launch command, never the
    # dispatcher's own process. Resolve the physical form of the
    # dispatcher dir (which may be set via env to a logical path).
    local dispatcher_phys; dispatcher_phys=$(cd "$DISPATCHER_DIR" && pwd -P)
    local md_excludes; md_excludes="{\"claudeMdExcludes\":[\"$dispatcher_phys/CLAUDE.md\",\"$dispatcher_phys/CLAUDE.local.md\"]}"

    # Conversation display name passed to `claude --name`. Stable, repo-prefixed
    # so the prompt box / /resume picker / terminal title identify the teammate
    # at a glance instead of using claude's auto-generated label.
    #
    #   --task <slug>          -> <repo>-<sanitized-slug>
    #   fresh, no --task       -> <repo>-<rand4>
    #   --resume + no --task   -> empty: keep the existing session's name as-is
    #   --resume + --task      -> <repo>-<sanitized-slug> (explicit relabel)
    local display_name=""
    if [[ -n "$task" ]]; then
        local slug; slug=$(sanitize_task_slug "$task")
        [[ -n "$slug" ]] || die "tm spawn: --task '$task' has no usable characters after sanitization (allowlist: ASCII letters/digits + CJK Unified Ideographs)"
        display_name="${repo}-${slug}"
    elif [[ -z "$resume_sid" ]]; then
        display_name="${repo}-$(rand_suffix)"
    fi
    local name_arg=""
    [[ -n "$display_name" ]] && name_arg=" -n '$display_name'"

    local name; name=$(session_name "$repo")
    if tmux has-session -t "=$name" 2>/dev/null; then
        # With --prompt, returning success silently would drop the user's
        # prompt — they think the atomic bootstrap succeeded but nothing
        # was sent. Die clearly so the caller routes to 'tm send' (which
        # is the right verb for "session already up, send a prompt").
        if (( has_prompt )); then
            die "$repo already exists (tmux=$name) — atomic bootstrap rejected because the teammate is already running. Use 'tm send $repo --prompt \"…\"' to drive an existing teammate, or 'tm kill $repo' first to start over."
        fi
        echo "$repo already exists (tmux=$name; use 'tm status $repo' to view, or 'tm kill $repo' first)"
        return 0
    fi

    # Clear the readiness signal BEFORE launching claude. The
    # SessionStart hook (on-session-start.sh) re-touches this file once
    # claude's REPL is up; the poll loop below blocks until it appears,
    # replacing the previous fixed "sleep 8".
    local rf; rf=$(ready_file "$repo")
    rm -f "$rf"

    # Record the teammate's physical cwd so the SessionStart hook can
    # identify "is the firing claude session this teammate?" by byte-exact
    # path match. Written BEFORE new-session so the .cwd file is in place
    # the moment the hook can possibly fire.
    echo "$cwd_phys" > "$(cwd_file "$repo")"

    # -P -F prints the new session's internal id (e.g. `$21`); we use it
    # as the pane-target for the subsequent send-keys so we don't rely on
    # name prefix-match resolution.
    #
    # -e CLAUDEMUX_TEAMMATE_REPO=<repo> stamps a tmux-session env var that
    # claude (and the on-session-start hook it fires) inherit. The hook
    # uses this as a positive identity gate: only sessions launched by
    # `tm spawn` get the env var, so the dispatcher itself (or any ad-hoc
    # `cd <repo> && claude`) can never hijack /tmp/teammate-<repo>.sid
    # via cwd collision. The env survives /clear and /resume because
    # those don't restart the claude process.
    local pane; pane=$(tmux new-session -d -s "$name" -c "$cwd_phys" \
        -e "CLAUDEMUX_TEAMMATE_REPO=$repo" -P -F '#{session_id}')
    local sid sf; sf=$(sid_file "$repo")
    local name_note=""
    [[ -n "$display_name" ]] && name_note=", name=$display_name"
    if [[ -n "$resume_sid" ]]; then
        sid="$resume_sid"
        tmux send-keys -t "$pane" "claude --resume $sid --settings '$md_excludes'$name_arg" Enter
        echo "spawned: $repo (tmux=$name, cwd=$cwd_phys, resumed sid=$sid$name_note)" >&2
    else
        # Pre-generate the UUID so the sid is known the moment spawn returns.
        # No more jsonl scanning, no race window: --session-id makes the jsonl
        # filename equal to this UUID, and the global Stop hook touches
        # /tmp/claude-idle/<that-same-uuid> on every turn-end.
        sid=$(new_sid)
        tmux send-keys -t "$pane" "claude --session-id $sid --settings '$md_excludes'$name_arg" Enter
        echo "spawned: $repo (tmux=$name, cwd=$cwd_phys, sid=$sid$name_note)" >&2
    fi
    echo "$sid" > "$sf"
    clear_idle "$sid"

    # Fresh-spawn .last sentinel. clear_idle removed any stale file; write
    # an empty one so a subsequent 'tm last' returns "no reply yet" (the
    # -s check fails on zero bytes) instead of reading whatever happened
    # to live at $IDLE_DIR/$sid.last from an earlier, unrelated session.
    # Resume mode skips this: the resumed session's last-turn text is
    # legitimate context the dispatcher may want to re-read.
    if [[ -z "$resume_sid" ]]; then
        # mkdir before the truncate: on a fresh system (post-reboot /tmp
        # wipe, or a user who never ran /claudemux:setup) the dir may not
        # exist, and `set -e` would abort spawn on that. clear_idle uses
        # rm -f which is tolerant; the truncate is not.
        mkdir -p "$IDLE_DIR"
        : > "$IDLE_DIR/$sid.last"
    fi

    # Poll for spawn readiness. The hook fires once the SessionStart
    # event reaches it; in practice that's within 2–4 s on a warm Mac,
    # so the 18 s cap (60 × 0.3 s) is generous. On timeout we surface a
    # warning but return successfully — callers can still try `tm send`.
    # Caveat: if claude failed to boot inside the tmux session, the
    # session exists but is just a dead shell; require_session passes
    # for that, keys get typed into nothing, and the subsequent wait
    # phase blocks until --timeout (default 600s) expires waiting for a
    # Stop hook that will never fire. The warning below is the
    # dispatcher's signal that this risk is now live.
    local i ready_after_ms=""
    for i in $(seq 1 60); do
        if [[ -f "$rf" ]]; then
            ready_after_ms=$(( i * 300 ))
            break
        fi
        sleep 0.3
    done
    if [[ -n "$ready_after_ms" ]]; then
        echo "ready: $repo (tmux=$name, SessionStart fired after ~${ready_after_ms} ms)" >&2
    else
        echo "WARN: $repo (tmux=$name) did not signal ready within 18s (no SessionStart hook fire — the plugin's on-session-start.sh may not be loaded, or claude failed to boot). Continuing, but if the REPL is actually dead, a subsequent sync 'tm send' / 'tm spawn --prompt' / 'tm compact' will block until its --timeout expires (default 600s). 'tm status $repo' shows the live pane if you need to verify." >&2
    fi

    # --prompt: atomic bootstrap. Wait 3s for the REPL to fully settle
    # (matches cmd_resume's pre-send sleep — the ready hook fires when
    # SessionStart reaches the plugin, but the prompt box isn't always
    # accepting input the same millisecond), then hand off to cmd_send.
    # cmd_send is sync-by-default, so without --no-wait this returns the
    # first turn's .last on stdout. With --no-wait it's fire-and-forget.
    if (( has_prompt )); then
        sleep 3
        # Bash 3.2 + set -u: "${arr[@]}" on an empty array trips
        # "unbound variable". The ${arr[@]+...} form makes the splat a
        # no-op when the array has no elements, which is what we want
        # whenever --no-wait was not passed.
        local _nw=(); (( no_wait )) && _nw=(--no-wait)
        cmd_send ${_nw[@]+"${_nw[@]}"} "$repo" --prompt "$prompt"
    fi
}

cmd_status() {
    local repo="${1:-}"; local lines="${2:-80}"
    [[ -n "$repo" ]] || die "usage: tm status <repo> [lines=80]"
    require_session "$repo" >/dev/null
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"
    tmux capture-pane -t "$pane" -p -S "-${lines}"
}

cmd_send() {
    # Atomic round-trip by default: send prompt + wait for Stop hook + print
    # .last text to stdout. Status messages ("sent to ...", "sid=...") go to
    # stderr so stdout is exclusively reply text — pipe-friendly for
    # `tm send <repo> --prompt "..." | jq`.
    #
    # See `tm send --help` for the full flag contract.
    local no_wait=0 pane_quiet=0 timeout=600 repo="" prompt="" has_prompt=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-wait)    no_wait=1; shift ;;
            --pane-quiet) pane_quiet=1; shift ;;
            --timeout)    [[ $# -ge 2 ]] || die "tm send: --timeout requires a value"
                          timeout="$2"; shift 2 ;;
            --timeout=*)  timeout="${1#--timeout=}"; shift ;;
            --prompt)     [[ $# -ge 2 ]] || die "tm send: --prompt requires a value"
                          prompt="$2"; has_prompt=1; shift 2 ;;
            --prompt=*)   prompt="${1#--prompt=}"; has_prompt=1; shift ;;
            --) shift; repo="${1:-}"; shift || true; break ;;
            -*) die "tm send: unknown flag: $1" ;;
            *)
                if [[ -z "$repo" ]]; then
                    repo="$1"; shift
                else
                    # Echo the full remaining argv (`$*`) so a multi-token
                    # legacy call like `tm send repo run tests` shows the
                    # complete intent (--prompt 'run tests'), not just the
                    # first token. printf %q shell-escapes the value so
                    # single quotes / metacharacters in the prompt render
                    # as a valid, copy-pasteable command.
                    die "tm send: prompt is now a --prompt flag, not a positional arg. Did you mean: tm send $repo --prompt $(printf %q "$*") ?"
                fi
                ;;
        esac
    done
    [[ -n "$repo" ]] || die "tm send: missing <repo>. Usage: tm send <repo> --prompt \"...\" [--no-wait] [--pane-quiet] [--timeout N]"
    (( has_prompt )) || die "tm send: missing --prompt. Usage: tm send <repo> --prompt \"...\" [--no-wait] [--pane-quiet] [--timeout N]"

    _send_keys "$repo" "$prompt"

    if (( no_wait )); then
        return 0
    fi

    local waiter_rc=0
    if (( pane_quiet )); then
        _wait_pane_quiet "$repo" "$timeout" || waiter_rc=$?
    else
        _wait_idle_signal "$repo" "$timeout" || waiter_rc=$?
    fi

    if (( waiter_rc != 0 )); then
        local _wait_kind="Stop hook"
        (( pane_quiet )) && _wait_kind="pane-quiet"
        echo "tm send: timed out after ${timeout}s waiting for $_wait_kind on $repo" >&2
        # Best-effort partial: if the signal landed between our last poll
        # and here, dump whatever .last has so stdout isn't silently empty.
        _print_last_or_empty "$repo"
        return 1
    fi

    # Pane-quiet path produces no assistant turn (TUI-only commands like
    # /help fire no Stop and don't update jsonl), so the ctx echo would be
    # the stale prior-turn number — skip it. Hook path always produces a
    # fresh usage block.
    (( pane_quiet )) || _echo_ctx_to_stderr "$repo"
    _print_last_or_empty "$repo"
    return 0
}

cmd_wait() {
    # Block on the Stop-hook idle marker (default) or pane-quiet
    # fallback, then print the teammate's last-turn reply to stdout. Use
    # when an external actor (Remote Control web UI, mobile app, cron) is
    # driving the teammate and the dispatcher needs to collect the reply
    # without sending its own prompt.
    #
    # Flags:
    #   --fresh          clear the idle/.last/.busy baseline up front so
    #                    the NEXT Stop is what wakes us up, not a past
    #                    one. Required when monitoring an autonomously
    #                    progressing teammate (no fresh `tm send` to
    #                    reset the baseline for you).
    #   --pane-quiet     fall back to pane-quiet detection. Same use case
    #                    as on cmd_send: TUI-only commands that fire no
    #                    hook (/help, /effort, /agents, permission prompt).
    #   --timeout N      override the 600s default wait cap.
    local repo="" timeout=600 fresh=0 pane_quiet=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --fresh)      fresh=1; shift ;;
            --pane-quiet) pane_quiet=1; shift ;;
            --timeout)    timeout="${2:-}"; shift 2 ;;
            --timeout=*)  timeout="${1#--timeout=}"; shift ;;
            -*) die "tm wait: unknown flag: $1" ;;
            *)
                if [[ -z "$repo" ]]; then repo="$1"
                else timeout="$1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$repo" ]] || die "usage: tm wait <repo> [timeout=600] [--fresh] [--pane-quiet] [--timeout N]"

    local waiter_rc=0
    if (( pane_quiet )); then
        # Pane-quiet has no sid-keyed marker to clear, so --fresh is a
        # no-op for it. The "min 3s since send" gate inside _wait_pane_quiet
        # already provides the freshness guarantee for the typical
        # tm send + tm wait --pane-quiet flow.
        _wait_pane_quiet "$repo" "$timeout" || waiter_rc=$?
    else
        _wait_idle_signal "$repo" "$timeout" "$fresh" || waiter_rc=$?
    fi

    if (( waiter_rc != 0 )); then
        echo "tm wait: timed out after ${timeout}s on $repo" >&2
        _print_last_or_empty "$repo"
        return 1
    fi

    # See note in cmd_send: pane-quiet has no fresh usage block.
    (( pane_quiet )) || _echo_ctx_to_stderr "$repo"
    _print_last_or_empty "$repo"
    return 0
}

cmd_last() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm last <repo>"
    local sid; sid=$(resolve_sid_or_die "$repo")
    local lf="$IDLE_DIR/$sid.last"
    # Two empty states are both treated as "no reply yet":
    #   - file missing: never written, or rm'd by clear_idle between send and Stop
    #   - file zero bytes: fresh-spawn sentinel, or a Stop hook that
    #     extracted no text (tool-only turn, /compact, /clear)
    # The -s test covers both (false on missing AND on zero bytes). Without
    # this guard a freshly spawned teammate would have `tm last` silently
    # succeed with empty stdout, which is the bug that motivated the
    # empty-sentinel write at spawn time.
    [[ -s "$lf" ]] \
        || die "no reply yet for $repo (sid=$sid) — file is missing or empty at $lf. Try 'tm wait $repo' to block for the next Stop, or 'tm send $repo --prompt \"...\"' to drive a turn."
    cat "$lf"
}

# Missing-memory path is exit 0 + stderr one-liner, NOT an error: the
# dispatcher calls this opportunistically before composing a spawn/send
# prompt, and a repo that has never run claude (or has had its project
# dir pruned) is a normal "no sibling memory available" case. Caller
# treats empty stdout as "proceed without sibling context." The path
# encoding routes through project_dir_for_repo so this site shares the
# single source of truth with cmd_resume / cmd_history / _ctx_format_line.
cmd_mem() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm mem <repo>"
    local path="$DISPATCHER_DIR/$repo"
    [[ -d "$path" ]] || die_repo_not_found mem "$repo" "$path"
    local mfile; mfile="$(project_dir_for_repo "$repo")/memory/MEMORY.md"
    if [[ ! -f "$mfile" ]]; then
        echo "tm mem: no auto-memory recorded for $repo (looked at $mfile)" >&2
        return 0
    fi
    cat "$mfile"
}

cmd_kill() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm kill <repo>"
    local name; name=$(session_name "$repo")
    local sid=""
    if sid=$(resolve_sid "$repo"); then
        clear_idle "$sid" || true
    fi
    rm -f "$(sid_file "$repo")" "$(send_at_file "$repo")" "$(ready_file "$repo")" "$(cwd_file "$repo")"
    if tmux has-session -t "=$name" 2>/dev/null; then
        tmux kill-session -t "=$name"
        echo "killed: $repo (tmux=$name)"
    else
        echo "not running: $repo (tmux=$name)"
    fi
}

cmd_reload() {
    # Fan out /reload-plugins to one, many, or all teammates. Sugar over
    # `tm send <repo> --prompt /reload-plugins` so the dispatcher doesn't
    # have to type it per pane after publishing a plugin update.
    local all=0
    local repos=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all) all=1; shift ;;
            -h|--help) die "usage: tm reload <repo>... | --all" ;;
            -*) die "tm reload: unknown flag: $1" ;;
            *) repos+=("$1"); shift ;;
        esac
    done

    if (( all )); then
        [[ ${#repos[@]} -eq 0 ]] || die "tm reload: --all conflicts with explicit repos"
        while IFS= read -r r; do
            [[ -n "$r" ]] && repos+=("$r")
        done < <(iter_repos)
        if [[ ${#repos[@]} -eq 0 ]]; then
            echo "(no teammate sessions to reload)"
            return 0
        fi
    elif [[ ${#repos[@]} -eq 0 ]]; then
        die "usage: tm reload <repo>... | --all"
    fi

    local repo rc=0
    for repo in "${repos[@]}"; do
        echo "→ $repo: /reload-plugins"
        # Use --no-wait so the fan-out stays fire-and-forget: cmd_send
        # is now sync by default, and waiting for every teammate's Stop
        # signal across a large fleet would serialize the reload into
        # minutes. Track first failure for the exit code, but keep
        # iterating so a missing teammate doesn't block the rest.
        if ! cmd_send --no-wait "$repo" --prompt "/reload-plugins" >/dev/null 2>&1; then
            echo "  (failed — is this teammate running? try 'tm ls')" >&2
            rc=1
        fi
    done
    return $rc
}

cmd_resume() {
    # Resume a prior conversation. The recommended call form is
    #     tm resume <repo> <sid>
    # with the sid pulled from the dispatcher's task ledger (each tracked
    # task records the sid of the teammate that owned it). When called
    # without a sid we fall back to "newest jsonl by mtime" as a one-off
    # convenience — that's NOT the typical workflow because the latest
    # jsonl is not necessarily the one you mean to continue.
    #
    # --prompt is the atomic-bootstrap-after-resume form: spawn the
    # resumed REPL, settle for 3s, then send the prompt via the sync
    # cmd_send (waits for Stop, prints .last). Pair with --no-wait to
    # fire-and-forget the follow-up message.
    local repo="" sid="" prompt="" has_prompt=0 task="" no_wait=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --prompt) [[ $# -ge 2 ]] || die "tm resume: --prompt requires a value"
                      prompt="$2"; has_prompt=1; shift 2 ;;
            --prompt=*) prompt="${1#--prompt=}"; has_prompt=1; shift ;;
            --task) task="${2:-}"; shift 2 ;;
            --task=*) task="${1#--task=}"; shift ;;
            --no-wait) no_wait=1; shift ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *)
                if [[ -z "$repo" ]]; then repo="$1"
                elif [[ -z "$sid" ]]; then sid="$1"
                else die "tm resume: too many positional args (got '$1' after repo='$repo' sid='$sid')"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$repo" ]] || die "usage: tm resume <repo> [<sid>] [--task <slug>] [--prompt \"...\"] [--no-wait]  (sid from ledger preferred; auto-pick on omit; --task relabels the resumed conversation; --no-wait only with --prompt)"
    if (( no_wait )) && ! (( has_prompt )); then
        die "tm resume: --no-wait is only valid with --prompt"
    fi

    local path="$DISPATCHER_DIR/$repo"
    [[ -d "$path" ]] || die_repo_not_found resume "$repo" "$path"

    local name; name=$(session_name "$repo")
    if tmux has-session -t "=$name" 2>/dev/null; then
        die "$repo already running (tmux=$name) — 'tm kill $repo' first if you really want to start over"
    fi

    local project_dir; project_dir=$(project_dir_for_repo "$repo")

    if [[ -z "$sid" ]]; then
        # Auto-pick fallback. Warn so the caller notices the ledger lookup
        # was skipped — most resumes should target a specific task's sid.
        [[ -d "$project_dir" ]] || die "no project dir at $project_dir — has anyone ever run claude inside $path? Try 'tm spawn $repo' first."
        local latest
        # shellcheck disable=SC2012  # need mtime sort (`ls -t`); BSD find on macOS lacks `-printf`, so the GNU find alternative isn't portable
        latest=$(ls -t "$project_dir"/*.jsonl 2>/dev/null | head -1)
        [[ -n "$latest" ]] || die "no .jsonl transcripts under $project_dir — try 'tm spawn $repo' to start fresh."
        sid=$(basename "$latest" .jsonl)
        echo "tm resume: no sid given — auto-picked $sid (jsonl mtime $(stat -f %Sm "$latest")). Prefer passing the sid from your task ledger." >&2
    else
        # Explicit sid: prove it exists as a jsonl under this repo's project
        # dir. Claude's --resume on an unknown sid produces a confusing
        # "session not found" deep inside the TUI; failing early here is
        # nicer.
        local target="$project_dir/$sid.jsonl"
        [[ -f "$target" ]] || die "no transcript at $target — wrong repo for this sid, or sid does not exist. Check 'ls $project_dir/'."
    fi

    [[ "$sid" =~ ^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$ ]] \
        || die "sid is not a valid uuid: $sid"

    if [[ -n "$task" ]]; then
        cmd_spawn "$repo" --resume "$sid" --task "$task"
    else
        cmd_spawn "$repo" --resume "$sid"
    fi

    if (( has_prompt )); then
        # Give the resumed claude a moment to render its banner / restore
        # state before sending. Empirically 3s is enough on a warm Mac.
        # cmd_send is sync-by-default, so without --no-wait this returns
        # the first-turn .last on stdout.
        sleep 3
        local _nw=(); (( no_wait )) && _nw=(--no-wait)
        cmd_send ${_nw[@]+"${_nw[@]}"} "$repo" --prompt "$prompt"
    fi
}

cmd_states() {
    local rows
    rows=$( { tmux ls 2>/dev/null || true; } | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print $1}')
    if [[ -z "$rows" ]]; then
        echo "(no teammate sessions)"
        return 0
    fi
    local now; now=$(date +%s)
    {
        printf 'REPO\tSID\tBUSY\tLAST\tPREVIEW\n'
        while IFS= read -r name; do
            local repo="${name#"$PREFIX"}"
            local sid sid_short busy last preview
            if sid=$(resolve_sid "$repo"); then
                sid_short="${sid:0:8}"
            else
                sid="" sid_short="?"
            fi
            if pane_busy "$repo"; then busy="yes"; else busy="no"; fi
            last="-"
            preview="-"
            if [[ -n "$sid" ]]; then
                local lf="$IDLE_DIR/$sid.last"
                if [[ -s "$lf" ]]; then
                    local sz lmt age
                    sz=$(wc -c < "$lf" | tr -d ' ')
                    lmt=$(stat -f %m "$lf" 2>/dev/null || echo 0)
                    age=$((now - lmt))
                    last="${sz}B/$(fmt_age "$age")"
                    # Sanitize the preview: strip control chars and tabs so
                    # column -t doesn't split a column, then truncate to 50
                    # *characters* (not bytes). macOS `cut -c` counts bytes,
                    # which mangles CJK (UTF-8 3 bytes/char → half-character
                    # tails). perl -CSD enables UTF-8 layers on STDIN/STDOUT
                    # regardless of locale, so substr counts characters; the
                    # chomp avoids embedding a stray newline in the table row.
                    preview=$(head -1 "$lf" | tr -d '\000-\037' \
                        | perl -CSD -ne 'chomp; print substr($_, 0, 50); last')
                    [[ -z "$preview" ]] && preview="(no first line)"
                fi
            fi
            printf '%s\t%s\t%s\t%s\t%s\n' "$repo" "$sid_short" "$busy" "$last" "$preview"
        done <<< "$rows"
    } | column -t -s $'\t'
}

cmd_compact() {
    # Send /compact and verify that PostCompact actually fired. Returns
    # the single line "compacted" on stdout. Doesn't read ctx — that's a
    # separate concern; run `tm ctx <repo>` if you want the new size.
    #
    # Two non-success paths, both exit 1:
    #   1. Claude Code refuses with "Error: Not enough messages to
    #      compact" — that error path fires NO Stop/PostCompact hook, so
    #      we have to scan the pane to detect it. Without this check,
    #      the verb would hang to full timeout for a fundamentally
    #      already-finished operation.
    #   2. PostCompact never fires within timeout — compaction is genuinely
    #      hung or the hook is misconfigured. Default 600s because large
    #      contexts (~300k+) routinely take 3-4 minutes; the old 120s
    #      gave up well before compaction finished on 1M-window teammates.
    # Both `tm compact <repo> 300` and `tm compact <repo> --timeout 300`
    # are accepted; if both forms are passed, the one parsed last wins
    # (same rule as cmd_wait). Don't try to encode a precedence between
    # the two forms — they're equivalent inputs.
    local repo="" timeout=600
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --timeout)   timeout="${2:-}"; shift 2 ;;
            --timeout=*) timeout="${1#--timeout=}"; shift ;;
            -*) die "tm compact: unknown flag: $1" ;;
            *)
                if [[ -z "$repo" ]]; then repo="$1"
                else timeout="$1"
                fi
                shift
                ;;
        esac
    done
    [[ -n "$repo" ]] || die "usage: tm compact <repo> [timeout=600] [--timeout N]"

    require_session "$repo" >/dev/null
    local sid; sid=$(resolve_sid_or_die "$repo")
    local pane; pane=$(resolve_pane_target "$repo")

    echo "tm compact: sending /compact to $repo (sid=$sid, timeout=${timeout}s)" >&2

    # _send_keys clears <sid>, <sid>.last, <sid>.busy before sending, so
    # the idle-marker check below targets THIS /compact, not a leftover
    # from the prior Stop.
    _send_keys "$repo" "/compact" >/dev/null

    local end; end=$(( $(date +%s) + timeout ))
    while [[ $(date +%s) -lt $end ]]; do
        # PostCompact succeeded — on-stop.sh touched the idle marker.
        if [[ -e "$IDLE_DIR/$sid" ]]; then
            echo "compacted"
            return 0
        fi
        # Error path: Claude Code renders the rejection as a tool-result
        # block under the /compact prompt echo — "⎿  Error: Not enough
        # messages to compact." — fires no hook, and leaves the session
        # idle with .busy still set. Anchor on the "⎿  Error:" decorator
        # so a user prompt that happens to mention the phrase doesn't
        # cause a false positive via prompt echo. Look only at the
        # visible pane (no -S); the line is the last thing on screen at
        # the moment of rejection.
        if [[ -n "$pane" ]] && tmux capture-pane -t "$pane" -p 2>/dev/null \
            | grep -q '⎿  Error: Not enough messages to compact'; then
            echo "tm compact: $repo refused /compact — Claude Code reported 'Not enough messages to compact' (transcript too short)." >&2
            return 1
        fi
        sleep 3
    done

    echo "tm compact: $repo did not signal PostCompact within ${timeout}s — compaction may still be running, or the Stop hook is misconfigured. Check 'tm status $repo' and /tmp/claude-idle/$sid." >&2
    return 1
}

cmd_poll() {
    local repo="${1:-}"; local pattern="${2:-}"; local timeout="${3:-180}"
    [[ -n "$repo" && -n "$pattern" ]] || die "usage: tm poll <repo> <regex> [timeout=180]"
    require_session "$repo" >/dev/null
    local pane; pane=$(resolve_pane_target "$repo")
    [[ -n "$pane" ]] || die "could not resolve pane target for $repo"

    # Useful gotcha: do not poll for a string that appears verbatim in the
    # prompt you just sent — capture-pane will see the prompt echo and match
    # immediately. Match expected RESULT keywords instead (e.g. Scheduled,
    # Cancelled, ✓, error). For "wait until teammate is done", prefer
    # 'tm wait' which uses the Stop-hook signal and doesn't need a regex.
    local end; end=$(( $(date +%s) + timeout ))
    while [[ $(date +%s) -lt $end ]]; do
        if tmux capture-pane -t "$pane" -p -S -300 2>/dev/null | grep -qE "$pattern"; then
            echo "matched: $pattern"
            return 0
        fi
        sleep 3
    done
    echo "tm: timeout after ${timeout}s waiting for /$pattern/ in $repo" >&2
    return 1
}

# Move a finished task from the active ledger to the archive — the mechanical
# half of "Archiving a finished task" in the dispatcher skill. Cuts the entry
# block out of active-dispatcher-tasks.md, copies repo/branch/intent verbatim
# from it, stamps the closed date, and prepends a compressed entry to
# dispatcher-tasks-archive.md (newest on top), creating that file from its
# shape if absent. The judgment half — the one/two-line outcome — is the
# dispatcher's and arrives on stdin.
cmd_archive() {
    local id="" status=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --status)   status="${2:-}"; shift 2 ;;
            --status=*) status="${1#--status=}"; shift ;;
            -*)         die "tm archive: unknown flag: $1" ;;
            *)          if [[ -z "$id" ]]; then id="$1"; else die "tm archive: unexpected arg: $1"; fi; shift ;;
        esac
    done
    [[ -n "$id" ]] || die "usage: tm archive <id> [--status '<tag>']   (outcome text on stdin)"

    local mdir; mdir=$(memory_dir)
    local active="$mdir/active-dispatcher-tasks.md"
    local archive="$mdir/dispatcher-tasks-archive.md"
    [[ -f "$active" ]] || die "no active ledger at $active"

    # The outcome — the one part that needs dispatcher judgment — comes in on
    # stdin so multi-word / URL-bearing text needs no argv quoting.
    local outcome; outcome=$(cat)
    [[ -n "${outcome//[[:space:]]/}" ]] || die "outcome text required on stdin, e.g.:  echo '...' | tm archive $id"

    # Locate the entry block. The active header carries a trailing status tag
    # (e.g. '### t-... [PAUSED — ...]'), so match the id by prefix, not whole
    # line. The block runs to the next '### ' / '## ' header or EOF.
    # grep exits non-zero on no-match; with pipefail that would abort the
    # whole function inside a command substitution, so each grep pipeline that
    # may legitimately not match ends with `|| true`.
    local start; start=$(grep -n -E "^### ${id}([[:space:]]|$)" "$active" | head -1 | cut -d: -f1 || true)
    if [[ -z "$start" ]]; then
        die "id not found in active ledger: $id
  available: $(grep -oE '^### [^ ]+' "$active" | sed 's/^### //' | paste -sd' ' - 2>/dev/null || true)"
    fi
    local matches; matches=$(grep -c -E "^### ${id}([[:space:]]|$)" "$active" || true)
    (( matches == 1 )) || die "id matches $matches entries in active ledger: $id"

    local total; total=$(wc -l < "$active")
    local rel; rel=$(tail -n +"$((start + 1))" "$active" | grep -n -E '^(### |## )' | head -1 | cut -d: -f1 || true)
    local end
    if [[ -n "$rel" ]]; then end=$((start + rel - 1)); else end="$total"; fi

    local block; block=$(sed -n "${start},${end}p" "$active")

    # Carry over the active header's [status] tag unless --status overrides it.
    if [[ -z "$status" ]]; then
        local hdr; hdr=$(printf '%s\n' "$block" | head -1)
        if [[ "$hdr" =~ \[(.+)\][[:space:]]*$ ]]; then
            status="${BASH_REMATCH[1]}"
        else
            status="done"
        fi
    fi

    local repo branch intent
    repo=$(printf '%s\n' "$block"   | grep -m1 -E '^- repo:'   | sed -E 's/^- repo:[[:space:]]*//'   || true)
    branch=$(printf '%s\n' "$block" | grep -m1 -E '^- branch:' | sed -E 's/^- branch:[[:space:]]*//' || true)
    intent=$(printf '%s\n' "$block" | grep -m1 -E '^- intent:' | sed -E 's/^- intent:[[:space:]]*//' || true)
    [[ -n "$repo" ]]   || repo="(unknown)"
    [[ -n "$branch" ]] || branch="(unknown)"
    [[ -n "$intent" ]] || intent="(unknown)"

    local today; today=$(date +%Y-%m-%d)
    local entry="### ${id}  [${status}]
- repo/branch: ${repo} / ${branch}
- intent: ${intent}
- outcome: ${outcome}
- closed: ${today}"

    # Create the archive from its shape if it doesn't exist yet.
    if [[ ! -f "$archive" ]]; then
        mkdir -p "$mdir"
        cat > "$archive" <<'ARCHIVE_EOF'
---
name: dispatcher-tasks-archive
description: "On-demand archive of closed dispatcher tasks, compressed to outcome + artifacts. NOT a boot read — only consult when looking up past task history. Live in-flight tasks live in active-dispatcher-tasks.md."
metadata:
  node_type: memory
  type: project
---

# Dispatcher task archive

Closed tasks moved here from `active-dispatcher-tasks.md`, compressed to a
pointer + conclusion (not a knowledge base). Newest on top. Reusable analysis
that outlives a task should be promoted to its own memory file, not kept here.

<!-- split by month (dispatcher-tasks-archive-YYYY-MM.md) if this file grows past a few hundred entries -->
ARCHIVE_EOF
    fi

    # Prepend the entry: insert above the first existing '### ' entry, or after
    # the header block if the archive has no entries yet.
    local tmp; tmp=$(mktemp)
    local first; first=$(grep -n -E '^### ' "$archive" | head -1 | cut -d: -f1 || true)
    if [[ -n "$first" ]]; then
        head -n "$((first - 1))" "$archive" > "$tmp"
        printf '%s\n\n' "$entry" >> "$tmp"
        tail -n +"$first" "$archive" >> "$tmp"
    else
        cat "$archive" > "$tmp"
        printf '\n%s\n' "$entry" >> "$tmp"
    fi
    mv "$tmp" "$archive"

    # Remove the original block from the active ledger.
    local tmp2; tmp2=$(mktemp)
    sed "${start},${end}d" "$active" > "$tmp2"
    mv "$tmp2" "$active"

    echo "archived $id  [$status] -> $(basename "$archive")  (removed from active ledger)"
}

# Report a teammate's real context-window usage from its session transcript.
# The TUI status-bar percentage is unreliable and absent in many environments;
# the jsonl usage block is the source of truth.
#
# ctx_used (current prompt size) = input_tokens + cache_creation_input_tokens
#   + cache_read_input_tokens of the most recent assistant message.
# next-turn estimate adds that message's output_tokens — this turn's output
#   becomes next turn's input.
#
# Window size is not recorded in the transcript. We detect 1M one-directionally:
# a 200k-window session auto-compacts well before 200k, so a peak ctx above
# ~210k proves a 1M window. Below that we assume 200k and label it as assumed;
# --window overrides.
cmd_ctx() {
    local window_override=""
    local repos=()
    local all=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)      all=1; shift ;;
            --window)   window_override="${2:-}"; shift 2 ;;
            --window=*) window_override="${1#--window=}"; shift ;;
            -*)         die "tm ctx: unknown flag: $1" ;;
            *)          repos+=("$1"); shift ;;
        esac
    done

    if [[ -n "$window_override" ]]; then
        case "$window_override" in
            200k|1m) ;;
            *) die "tm ctx: --window must be 200k or 1m" ;;
        esac
    fi

    if (( all )); then
        local r
        while IFS= read -r r; do [[ -n "$r" ]] && repos+=("$r"); done < <(iter_repos)
    fi
    [[ ${#repos[@]} -gt 0 ]] || die "usage: tm ctx <repo> [<repo>...] | --all  [--window 200k|1m]"

    local repo
    for repo in "${repos[@]}"; do
        ctx_one "$repo" "$window_override"
    done
}

# Format one teammate's ctx line WITHOUT the "<repo>: " prefix. Returns 0
# with the formatted line on stdout, or 1 (silently) on any read error.
# Used by both ctx_one (which prepends the prefix and prints '?' lines on
# soft failure) and the Stop-waiting verbs (cmd_send, cmd_wait, and their
# spawn/resume --prompt callers, all via the shared cmd_send path) which
# want to echo the current ctx to stderr right after a successful turn.
#
# window_override is optional (only ctx_one passes it); '1m' / '200k'
# force the assumption, anything else (or empty) uses the same heuristic
# as ctx_one — a peak usage above ~210k proves a 1M window.
_ctx_format_line() {
    local repo="$1" window_override="${2:-}"
    local sid; sid=$(resolve_sid "$repo") || return 1

    local cwd_f; cwd_f=$(cwd_file "$repo")
    local tcwd
    if [[ -s "$cwd_f" ]]; then tcwd=$(cat "$cwd_f"); else tcwd="$DISPATCHER_DIR/$repo"; fi
    local jsonl; jsonl="$(encode_project_dir "$tcwd")/$sid.jsonl"
    [[ -f "$jsonl" ]] || return 1

    local line
    line=$(jq -r -s '
        [ .[] | select(.type == "assistant" and (.message.usage != null)) | .message.usage ] as $u
        | if ($u | length) == 0 then "EMPTY"
          else ($u[-1]) as $l
            | "\($l.input_tokens + $l.cache_creation_input_tokens + $l.cache_read_input_tokens) \($l.output_tokens) \([ $u[] | .input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens ] | max)"
          end' "$jsonl" 2>/dev/null) || return 1
    [[ -n "$line" && "$line" != "EMPTY" ]] || return 1

    local used out peak
    read -r used out peak <<< "$line"
    local next=$((used + out))

    local window window_note
    if [[ "$window_override" == "1m" ]]; then
        window=1000000; window_note="flag"
    elif [[ "$window_override" == "200k" ]]; then
        window=200000; window_note="flag"
    elif (( peak > 210000 )); then
        window=1000000; window_note="detected 1M"
    else
        window=200000; window_note="assumed 200k"
    fi

    local pct=$(( used * 100 / window ))
    local wlabel; if (( window >= 1000000 )); then wlabel="1M"; else wlabel="200k"; fi
    printf '%s tokens · ~%s next turn · %s%% of %s (%s)\n' \
        "$used" "$next" "$pct" "$wlabel" "$window_note"
}

# Print one teammate's context line. Soft-fails (prints a '?' line, returns 0)
# so 'tm ctx --all' keeps going across teammates with no readable transcript.
# The actual computation lives in _ctx_format_line; this wrapper handles
# the user-facing prefix + the diagnostic '?' fallback lines.
ctx_one() {
    local repo="$1" window_override="$2"
    local body
    if body=$(_ctx_format_line "$repo" "$window_override" 2>/dev/null); then
        printf '%s: %s\n' "$repo" "$body"
        return 0
    fi

    # _ctx_format_line failed — figure out why so the '?' line is
    # informative. Mirror its early-exit conditions in the same order.
    local sid; sid=$(resolve_sid "$repo") || { echo "$repo: ? (no sid file)"; return 0; }
    local cwd_f; cwd_f=$(cwd_file "$repo")
    local tcwd
    if [[ -s "$cwd_f" ]]; then tcwd=$(cat "$cwd_f"); else tcwd="$DISPATCHER_DIR/$repo"; fi
    local jsonl; jsonl="$(encode_project_dir "$tcwd")/$sid.jsonl"
    if [[ ! -f "$jsonl" ]]; then
        echo "$repo: ? (no transcript at $jsonl)"
    else
        echo "$repo: ? (no assistant usage in transcript)"
    fi
}

# Inspect this repo's past Claude sessions (live or dead). Two modes:
#   tm history <repo>            list mode — newest-first table of jsonls
#   tm history <repo> <sid>      detail mode — one session's summary
# The detail mode accepts an 8+ char prefix and resolves to a unique full sid.
# Boundary with `tm last`: that command only covers the *current live*
# teammate's last turn (read from /tmp/claude-idle/<sid>.last). `tm history`
# operates on any jsonl on disk, including sessions whose teammate was killed.
cmd_history() {
    local repo="${1:-}"
    [[ -n "$repo" ]] || die "usage: tm history <repo> [<sid-or-prefix>]"
    local sid_arg="${2:-}"

    local path="$DISPATCHER_DIR/$repo"
    [[ -d "$path" ]] || die_repo_not_found history "$repo" "$path"
    local project_dir; project_dir=$(project_dir_for_repo "$repo")

    if [[ -z "$sid_arg" ]]; then
        history_list "$repo" "$project_dir"
    else
        history_detail "$repo" "$project_dir" "$sid_arg"
    fi
}

# Pull the first user prompt's text from a jsonl. Skip tool_result responses
# (whose .message.content is an array of tool_result blocks, no text). Cap the
# scan at the file head — a human first prompt is virtually always near the
# top, so a full-file slurp is wasted work in list mode.
history_first_prompt() {
    local f="$1"
    head -200 "$f" 2>/dev/null \
        | jq -r 'select(
                    .type == "user"
                    and .message.role == "user"
                    and (.message.content
                         | (type == "string")
                           or (type == "array" and any(.[]; .type == "text"))
                        )
                  )
                  | .message.content
                  | if type == "string" then .
                    else (map(select(.type == "text") | .text) | join(" "))
                    end' 2>/dev/null \
        | head -1
}

history_list() {
    local repo="$1" project_dir="$2"
    [[ -d "$project_dir" ]] || { echo "(no past sessions for $repo)"; return 0; }

    local files
    files=$(ls -t "$project_dir"/*.jsonl 2>/dev/null || true)
    [[ -n "$files" ]] || { echo "(no past sessions for $repo)"; return 0; }

    local live_sid=""
    local sf; sf=$(sid_file "$repo")
    [[ -s "$sf" ]] && live_sid=$(cat "$sf")

    local now; now=$(date +%s)

    {
        printf ' \tSID\tAGE\tSIZE\tTOPIC\n'
        while IFS= read -r f; do
            local fname sid_full sid_short mtime age size topic mark
            fname=$(basename "$f" .jsonl)
            sid_full="$fname"
            sid_short="${sid_full:0:8}"
            mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)
            age=$(fmt_age $((now - mtime)))
            size=$(fmt_size "$f")
            topic=$(history_first_prompt "$f" \
                | tr -d '\000-\037' \
                | perl -CSD -ne 'chomp; print substr($_, 0, 60); last' 2>/dev/null \
                || true)
            [[ -z "$topic" ]] && topic="(no user prompt)"
            mark=" "
            [[ -n "$live_sid" && "$sid_full" == "$live_sid" ]] && mark="*"
            printf '%s\t%s\t%s\t%s\t%s\n' "$mark" "$sid_short" "$age" "$size" "$topic"
        done <<< "$files"
    } | column -t -s $'\t'
}

history_detail() {
    local repo="$1" project_dir="$2" prefix="$3"

    [[ "$prefix" =~ ^[0-9a-f-]{1,36}$ ]] \
        || die "tm history: invalid sid prefix '$prefix' — must match ^[0-9a-f-]{1,36}\$"
    [[ -d "$project_dir" ]] \
        || die "tm history: no project dir at $project_dir for $repo (no sessions yet)"

    # Resolve prefix -> unique jsonl. find avoids the "literal glob" gotcha
    # that bare ls would hit when the pattern doesn't expand.
    local matches
    matches=$(find "$project_dir" -maxdepth 1 -name "${prefix}*.jsonl" -type f 2>/dev/null | sort)
    [[ -n "$matches" ]] || die "tm history: no session matching '$prefix' in $repo"
    local count; count=$(printf '%s\n' "$matches" | wc -l | tr -d ' ')
    if (( count > 1 )); then
        local cands; cands=$(printf '%s\n' "$matches" | xargs -n1 basename | sed 's/\.jsonl$//' | tr '\n' ' ')
        die "tm history: prefix '$prefix' matches $count sessions — be more specific: $cands"
    fi

    local f="$matches"
    local sid_full; sid_full=$(basename "$f" .jsonl)
    local size; size=$(fmt_size "$f")
    local lines; lines=$(wc -l < "$f" | tr -d ' ')
    local mtime; mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)
    local now; now=$(date +%s)
    local age; age=$(fmt_age $((now - mtime)))
    local last_seen; last_seen=$(date -r "$mtime" '+%Y-%m-%d %H:%M:%S')

    # One jq -s pass over the whole file, returning a tab-delimited row of:
    #   <first-prompt-base64> <last-assistant-base64> <created-ts> <used> <out> <peak>
    # base64 around the multi-line text fields keeps the pipeline newline-safe;
    # bash decodes them after splitting.
    local data
    data=$(jq -r -s '
        [ .[] | select(
                  .type == "user" and .message.role == "user"
                  and (.message.content
                       | (type == "string")
                         or (type == "array" and any(.[]; .type == "text"))
                      )
                ) | .message.content
                  | if type == "string" then .
                    else (map(select(.type == "text") | .text) | join(" "))
                    end
        ] as $u_prompts
        | [ .[] | select(
                    .type == "assistant"
                    and (.message.content
                         | type == "array" and any(.[]; .type == "text")
                        )
                  ) | .message.content
                    | map(select(.type == "text") | .text) | join("\n")
          ] as $a_texts
        | [ .[] | select(.type == "assistant" and .message.usage != null)
                | .message.usage
          ] as $u
        | [ .[] | select(.timestamp != null) | .timestamp ] as $ts
        | (($u_prompts[0] // "") | @base64) + "\t"
          + (($a_texts[-1] // "") | @base64) + "\t"
          + ($ts[0] // "") + "\t"
          + (if ($u | length) > 0
             then ($u[-1].input_tokens + $u[-1].cache_creation_input_tokens + $u[-1].cache_read_input_tokens | tostring)
             else "" end) + "\t"
          + (if ($u | length) > 0 then ($u[-1].output_tokens | tostring) else "" end) + "\t"
          + (if ($u | length) > 0
             then ([$u[] | .input_tokens + .cache_creation_input_tokens + .cache_read_input_tokens] | max | tostring)
             else "" end)
    ' "$f" 2>/dev/null || echo $'\t\t\t\t\t')

    local fp_b64 la_b64 created_ts used out peak
    IFS=$'\t' read -r fp_b64 la_b64 created_ts used out peak <<< "$data"

    local first_prompt last_assistant
    first_prompt=$(printf '%s' "$fp_b64" | base64 --decode 2>/dev/null || true)
    last_assistant=$(printf '%s' "$la_b64" | base64 --decode 2>/dev/null || true)

    local created_str=""
    if [[ -n "$created_ts" ]]; then
        # ISO 8601 like 2026-05-12T14:21:33.000Z -> 2026-05-12 14:21:33
        created_str=$(printf '%s' "$created_ts" | sed -E 's/T/ /; s/\.[0-9]+Z?$//; s/Z$//')
    fi

    local ctx_str="(no usage data)"
    if [[ -n "$used" && -n "$peak" ]]; then
        local window window_note pct wlabel
        if (( peak > 210000 )); then window=1000000; window_note="detected 1M"
        else                          window=200000;  window_note="assumed 200k"; fi
        pct=$(( used * 100 / window ))
        if (( window >= 1000000 )); then wlabel="1M"; else wlabel="200k"; fi
        ctx_str="$used tokens · $pct% of $wlabel ($window_note)"
    fi

    # Truncate last assistant by character count (not byte) to handle CJK.
    local la_display="${last_assistant:-(no assistant text)}"
    if [[ -n "$last_assistant" ]]; then
        local la_len
        la_len=$(printf '%s' "$last_assistant" | perl -CSD -e 'local $/; my $s=<>; print length $s' 2>/dev/null || echo 0)
        if (( la_len > 1500 )); then
            la_display=$(printf '%s' "$last_assistant" | perl -CSD -e 'local $/; my $s=<>; print substr($s, 0, 1500)' 2>/dev/null)
            la_display+=$'\n... ('"$((la_len - 1500))"' chars truncated; full text in jsonl)'
        fi
    fi

    local fp_display="${first_prompt:-(no user prompt)}"

    cat <<EOF
sid:        $sid_full
file:       $f
            ($size · $lines lines)
created:    ${created_str:-(unknown)}
last_seen:  $last_seen  ($age ago)
ctx:        $ctx_str

first prompt:
$(printf '%s' "$fp_display" | sed 's/^/  /')

last assistant:
$(printf '%s' "$la_display" | sed 's/^/  /')

resume: tm resume $repo $sid_full
EOF
}

# Self-check for the dispatcher environment. Read-only — does not change any
# state, never dies (every probe is wrapped so set -e can't take it down on a
# missing dep or unreadable file); exit code is always 0. The output is meant
# to be eyeballed, not parsed. Sections fire top-down: tm executable, dispatcher
# dir, tmux, idle dir, active teammates.
cmd_doctor() {
    [[ $# -eq 0 ]] || die "tm doctor: takes no arguments (got: $*)"

    # Shared row helper: all sections pad the label column to a single
    # width so labels of different lengths line up without hand-counted
    # spaces. Renaming any label can't drift the alignment; sections
    # with shorter labels just get a slightly wider gap, which reads
    # consistent rather than ragged.
    kv() { printf '  %-20s%s\n' "$1:" "$2"; }

    # --- tm executable ---
    # macOS lacks GNU `readlink -f`; cd + `pwd -P` is the portable way
    # to resolve $0 to the absolute, symlink-resolved location of THIS
    # script. plugin.json sits at <plugin-root>/.claude-plugin/plugin.json
    # — from bin/tm that's `../.claude-plugin/plugin.json`. jq is a
    # documented dependency; on failure we degrade to "unknown" so
    # doctor still produces a useful report when the manifest is
    # missing or unreadable.
    local tm_dir tm_path
    tm_dir=$(cd "$(dirname "$0")" 2>/dev/null && pwd -P) || tm_dir=""
    if [[ -z "$tm_dir" ]]; then
        tm_path="$0 (unable to resolve)"
    else
        tm_path="$tm_dir/$(basename "$0")"
    fi
    local plugin_json="$tm_dir/../.claude-plugin/plugin.json"
    local version="unknown"
    if [[ -f "$plugin_json" ]]; then
        version=$(jq -r '.version // "unknown"' "$plugin_json" 2>/dev/null || echo unknown)
        [[ -n "$version" ]] || version="unknown"
    fi
    echo "tm executable:"
    kv path    "$tm_path"
    kv version "$version"
    [[ -f "$plugin_json" ]] || kv note "plugin.json not found at $plugin_json"
    echo

    # --- dispatcher dir ---
    # Distinguish "env was actually set" from "fell back to $PWD" — the
    # former proves /claudemux:setup wired the .claude/settings.json
    # correctly; the latter is the BC path and a hint that rerunning
    # setup would inoculate against cwd drift.
    echo "dispatcher dir:"
    kv resolved "$DISPATCHER_DIR"
    if [[ -n "${TM_DISPATCHER_DIR:-}" ]]; then
        kv TM_DISPATCHER_DIR "set (= $TM_DISPATCHER_DIR)"
    else
        # shellcheck disable=SC2016  # literal "$PWD" in user message — naming the shell var, not expanding it
        kv TM_DISPATCHER_DIR 'unset — falling back to $PWD (run /claudemux:setup to inoculate against cwd drift)'
    fi
    # shellcheck disable=SC2016  # literal "$PWD" as the label of the next row (the value is the real expansion)
    kv '$PWD' "$PWD"
    if [[ "$DISPATCHER_DIR" != "$PWD" ]]; then
        # shellcheck disable=SC2016  # literal "$PWD" in user message — naming the shell var, not expanding it
        kv status 'DIVERGED — dispatcher dir != $PWD; env override is currently keeping tm correct despite the drifted PWD'
    else
        kv status matched
    fi
    [[ -d "$DISPATCHER_DIR" ]] || kv warning "$DISPATCHER_DIR does not exist as a directory"
    echo

    # --- tmux ---
    echo "tmux:"
    if ! command -v tmux >/dev/null 2>&1; then
        kv installed 'no (tmux not on PATH — claudemux teammate workflow needs it)'
    else
        kv installed "yes ($(tmux -V 2>/dev/null || echo '?'))"
        if tmux info >/dev/null 2>&1; then
            kv server running
        else
            kv server "not running (no sessions exist yet — that's fine pre-spawn)"
        fi
        if [[ -n "${TMUX:-}" ]]; then
            kv 'in tmux' "yes (TMUX=$TMUX)"
        else
            kv 'in tmux' 'no — tm is being run from outside a tmux session'
        fi
    fi
    echo

    # --- idle dir ---
    echo "idle dir ($IDLE_DIR):"
    if [[ -d "$IDLE_DIR" ]]; then
        # shellcheck disable=SC2012  # `ls | wc -l` is idiomatic for a flat file count; the alternative (`find ... -maxdepth 1 ... | wc -l`) buys nothing for this trusted, claudemux-managed directory
        kv exists "yes ($(ls -1 "$IDLE_DIR" 2>/dev/null | wc -l | tr -d ' ') file(s))"
    else
        kv exists 'no — gets created on first tm spawn / scripts/setup.sh'
    fi
    echo

    # --- active teammates ---
    # Same prefix-match logic cmd_ls uses, but projected to name-only;
    # the three call sites (cmd_ls / cmd_states / here) all want
    # slightly different output, so each keeps its own awk projection.
    echo "active teammates:"
    local rows; rows=$( { tmux ls 2>/dev/null || true; } | awk -F: -v p="$PREFIX" '$1 ~ "^"p {print $1}')
    if [[ -z "$rows" ]]; then
        echo "  (none — use 'tm spawn <repo>' to launch one)"
    else
        kv count "$(printf '%s\n' "$rows" | wc -l | tr -d ' ')"
        printf '%s\n' "$rows" | sed 's/^/  - /'
    fi

    return 0
}

cmd_help() {
    # Top-level synopsis: one line per verb. The detailed per-verb
    # contracts live in help_<verb> functions below; both layers are
    # the authoritative tm command surface. The dispatcher SKILL.md
    # command table is kept in lockstep with this text — if they
    # disagree, the SKILL.md / this help are the ground truth and the
    # divergence is the bug.
    cat <<'EOF'
tm — tmux teammate manager for the dispatcher skill

Run `tm <verb> --help` (or `tm help <verb>`) for per-verb detail.

USAGE  (most common first)
  tm send <repo> --prompt "..."          atomic round-trip: send + wait + print reply
  tm spawn <repo> [--prompt "..."]       launch teammate; --prompt = atomic bootstrap
  tm wait <repo> [--fresh]               wait for next Stop; print reply
  tm compact <repo>                      /compact + verify, prints "compacted"
  tm resume <repo> [<sid>]               resume a prior conversation
  tm last <repo>                         reprint the last-turn reply
  tm kill <repo>                         kill the teammate's tmux session
  tm reload <repo>... | --all            fan out /reload-plugins
  tm ls                                  list running teammate sessions
  tm states                              one-line fleet snapshot
  tm ctx <repo>... | --all               real ctx-window usage from jsonl
  tm history <repo> [<sid-prefix>]       inspect past sessions for this repo
  tm mem <repo>                          cat sibling repo's auto-memory index
  tm archive <id>                        move finished task active→archive (stdin)

DIAGNOSTIC (escape hatches — prefer the verbs above)
  tm status <repo>                       capture-pane the teammate's live screen
  tm poll <repo> <regex>                 block until pane matches
  tm doctor                              self-check: tm path/version, env, tmux,
                                         idle dir, active teammates

HELP
  tm --help / tm -h / tm help            this text
  tm <verb> --help / tm help <verb>      detail for one verb

ENVIRONMENT
  TM_DISPATCHER_DIR    Dispatcher directory (parent of sibling repos).
                       scripts/setup.sh writes it into the dispatcher's
                       .claude/settings.json on first /claudemux:setup,
                       and Claude Code injects it as env at every
                       claude launch — so tm stays correct even when
                       the Bash tool's cwd drifts. Falls back to $PWD
                       when unset (backward compat for dispatchers set
                       up before this feature).
EOF
}

# --- Per-verb help texts ----------------------------------------------------
# Reached via either `tm <verb> --help` or `tm help <verb>` — main() routes
# both to help_<verb>. Keeping these as separate functions (rather than one
# giant case) means each cmd_<verb> evolves alongside its help text, and the
# top-level cmd_help stays a short index. Adding a new verb means: write
# cmd_<verb>, write help_<verb>, add one line to main's case + one row to
# cmd_help's synopsis.

help_ls() {
    cat <<'EOF'
tm ls

      List running teammate-<repo> sessions. Shows tmux's raw session
      row (name, window count, attached state). For a richer "who's
      doing what" view, prefer `tm states`.
EOF
}

help_states() {
    cat <<'EOF'
tm states

      One-line fleet snapshot: REPO, SID (first 8 chars), BUSY (yes
      if the .busy file from the on-busy hook is present), LAST
      (size + age of <sid>.last), PREVIEW (first 50 chars of last
      reply). Use to see what every teammate is doing at a glance.
EOF
}

help_spawn() {
    cat <<'EOF'
tm spawn <repo> [--task <slug>] [--prompt "..."] [--no-wait]

      Launch a claude teammate in <dispatcher-dir>/<repo>, where the
      dispatcher dir comes from TM_DISPATCHER_DIR (or $PWD fallback);
      fails with "repo not found" if <repo> isn't a direct
      subdirectory of it.
      Without --prompt, returns once the REPL signals SessionStart
      (typically 2-4s on a warm Mac). With --prompt "...", sleeps 3s
      after ready, sends the prompt, waits for Stop, and prints the
      teammate's first-turn reply on stdout — atomic bootstrap, one
      call. --no-wait combined with --prompt sends without waiting.
      --task <slug> names the conversation <repo>-<slug>. Allowlist:
      ASCII letters/digits + CJK Unified Ideographs (中日韩汉字).
      Without --task a fresh spawn auto-names <repo>-<rand4>.
      Fresh spawns also write an empty /tmp/claude-idle/<sid>.last
      sentinel, so 'tm last' before any reply returns a clear "no
      reply yet" error instead of stale content from an earlier sid.
      The --prompt sync path inherits 'tm send''s stderr ctx echo
      after the first-turn Stop.
EOF
}

help_send() {
    cat <<'EOF'
tm send <repo> --prompt "..." [--no-wait] [--pane-quiet] [--timeout N]

      Atomic round-trip by default: send prompt + wait for the Stop
      hook + print the teammate's reply text on stdout. The
      dispatcher's primary verb — folds what used to be send +
      wait-idle + last into one call. Stdout is exclusively reply
      text; status lines go to stderr (pipe-friendly).
      --prompt "..." the prompt text. Required. Same calling form
        as 'tm spawn --prompt' / 'tm resume --prompt'. Flag order is
        free: 'tm send <repo> --prompt "..."' and 'tm send --prompt
        "..." <repo>' both work.
      --no-wait fire-and-forget; return as soon as the keys are
        sent. Use for /clear before kill, or any case where the
        reply doesn't matter. (--pane-quiet has no effect with
        --no-wait, since nothing waits.)
      --pane-quiet falls back to pane-quiet detection. Use for
        TUI-only commands that fire no hook: /help, /effort,
        /agents, permission prompts. /compact and /clear do NOT
        need it — the Stop hook now covers them via PostCompact /
        SessionEnd.
      --timeout N overrides the 600s default wait.
      Empty stdout never silently means success: a turn with no text
      (tool-only, /compact, /clear) prints the sentinel line "(no
      text reply this turn — tool-only, /compact, /clear, or fresh
      spawn)".
      On the default (Stop-hook) path, also echoes the teammate's
      post-turn ctx to stderr as "ctx: N tokens · ~M next turn · X%
      of W (note)" — same data as 'tm ctx <repo>' inline with the
      reply. Skipped on --pane-quiet (no fresh usage block in jsonl)
      and --no-wait (nothing waited).
      On timeout: stderr warning, partial .last to stdout if any,
      exit 1.
EOF
}

help_wait() {
    cat <<'EOF'
tm wait <repo> [timeout=600] [--fresh] [--pane-quiet] [--timeout N]

      Block until the teammate's next Stop hook (or pane-quiet
      fallback), then print the reply to stdout — same output
      contract as 'tm send'. Use when an external actor (Remote
      Control web UI, mobile app, cron) drove the turn and you just
      want to collect the result.
      --fresh clears the idle/.last/.busy baseline up front so the
        NEXT Stop unblocks the wait, not a prior one. Required when
        monitoring an autonomously progressing teammate (no fresh
        'tm send' to reset the baseline for you). No-op under
        --pane-quiet (pane-quiet uses send-at timing instead of a
        sid-keyed marker; the "≥3s since last send" gate already
        provides the freshness guarantee).
      --pane-quiet falls back to pane-quiet detection (same use
        case as on 'tm send').
      --timeout N is the flag form of the positional [timeout=600];
        both forms are accepted, and if both are passed, whichever
        is parsed last wins.
      Stop-hook path also echoes ctx to stderr (see 'tm send');
      skipped on --pane-quiet.
EOF
}

help_compact() {
    cat <<'EOF'
tm compact <repo> [timeout=600] [--timeout N]

      Send /compact and verify PostCompact fired. Prints "compacted"
      on stdout when the Stop-hook idle marker is touched. Doesn't
      read ctx — run 'tm ctx <repo>' separately if you want the new
      size.
      Default timeout is 600s because large contexts (~300k+)
      routinely take 3-4 minutes to compact.
      Two non-success modes, both exit 1:
        - Claude Code refuses with "Not enough messages to compact"
          (transcript too short). That error fires no hook, so the
          pane is scanned alongside the idle-marker poll to detect
          it.
        - PostCompact never fires within timeout. Compaction is
          hung or the Stop hook is misconfigured.
EOF
}

help_resume() {
    cat <<'EOF'
tm resume <repo> [<sid>] [--task <slug>] [--prompt "..."] [--no-wait]

      Resume a prior conversation. PREFER passing <sid> from the
      dispatcher's task ledger (active-dispatcher-tasks.md records
      the sid of each teammate it spawned). Without sid, picks the
      newest jsonl by mtime as a one-off convenience (stderr
      warning). Validates the jsonl exists in the project dir; UUID
      format enforced. Fails if a teammate session for <repo>
      already exists.
      --prompt sends a follow-up after a 3s settle, atomic like
      'tm spawn --prompt' (inherits 'tm send''s stderr ctx echo on
      the sync path). --no-wait (with --prompt) fires without
      waiting. --task relabels the resumed conversation.
EOF
}

help_last() {
    cat <<'EOF'
tm last <repo>

      Print the teammate's last-turn reply from
      /tmp/claude-idle/<sid>.last. Empty or missing file dies with
      "no reply yet". Use this when you want to re-read a reply the
      send/wait verbs already printed (their output is one-shot).
EOF
}

help_mem() {
    cat <<'EOF'
tm mem <repo>

      Cat the sibling repo's auto-memory MEMORY.md to stdout. Use
      this before composing a `tm spawn` / `tm send --prompt` that
      references sibling state (feature-gate names, branch names,
      in-progress projects) — sibling memories live in separate
      per-cwd index files that the dispatcher's own AutoMemory does
      not include. Resolves the encoded project dir as
      $HOME/.claude/projects/<encoded>/memory/MEMORY.md where
      <encoded> = the repo's physical cwd with every `/` and `.`
      replaced by `-`. If no MEMORY.md exists for the repo (never
      ran claude, or its project dir was pruned), prints a one-line
      notice to stderr and returns 0 with empty stdout — that is
      the normal "no sibling memory" case, not an error.

      MEMORY.md entries can be stale. Verify any fact you are about
      to inject into a teammate's prompt against current code or
      git state before sending.
EOF
}

help_kill() {
    cat <<'EOF'
tm kill <repo>

      Kill the teammate's tmux session and clean up its state files
      (/tmp/teammate-<repo>.{sid,send-at,ready,cwd}).
EOF
}

help_reload() {
    cat <<'EOF'
tm reload <repo>... | --all

      Fan out /reload-plugins to one, many, or every teammate.
      Sugar over 'tm send <repo> --prompt /reload-plugins'. --all enumerates
      from `tmux ls`; missing/dead teammates are skipped with a
      stderr note and the exit status reflects whether every send
      succeeded.
EOF
}

help_ctx() {
    cat <<'EOF'
tm ctx <repo>... | --all [--window 200k|1m]

      Real context-window usage per teammate, read from the jsonl
      usage block (more accurate than the TUI percentage). Prints
      current prompt size, next-turn estimate, and percent of
      window.
      Window size is not in the transcript: a peak above ~210k
      proves a 1M window; otherwise 200k is assumed (labelled
      accordingly). --window forces the assumption.
EOF
}

help_history() {
    cat <<'EOF'
tm history <repo> [<sid-or-prefix>]

      Inspect this repo's past Claude sessions (live or dead). No
      <sid>: list mode, newest-first table (SID, AGE, SIZE, TOPIC =
      first user prompt). '*' marks the current live teammate's
      session. With <sid> or 8+ char prefix: detail mode (full sid,
      file path, created/last-seen, ctx usage, first prompt, last
      assistant text up to 1500 chars, ready-to-paste 'tm resume'
      command). Boundary vs 'tm last': last covers only the current
      live teammate's reply; history covers any jsonl on disk
      including killed sessions.
EOF
}

help_archive() {
    cat <<'EOF'
tm archive <id> [--status '<tag>']

      Move a finished task from the active ledger to the archive.
      Reads the compressed one/two-line outcome on stdin; copies
      repo/branch/intent verbatim from the active entry and stamps
      today's date. Prepends to dispatcher-tasks-archive.md (newest
      on top), creating it from its shape if absent, then deletes
      the entry from active-dispatcher-tasks.md. --status overrides
      the carried-over [status] tag.
EOF
}

help_status() {
    cat <<'EOF'
tm status <repo> [lines=80]

      Capture-pane the teammate's live screen. DIAGNOSTIC — the
      sync send/wait verbs make this unnecessary for normal flow.
      Reach for it only when you genuinely need the live pane (e.g.
      confirming a TUI dialog is up).
EOF
}

help_poll() {
    cat <<'EOF'
tm poll <repo> <regex> [timeout=180]

      Block until pane content matches a regex. DIAGNOSTIC fallback
      when `tm wait` can't catch an interesting intermediate state.
      Match the EXPECTED RESULT, not the prompt you just sent (a
      pattern that appears in the sent prompt makes the wait return
      instantly).
EOF
}

help_doctor() {
    cat <<'EOF'
tm doctor

      Self-check for the dispatcher environment. Reports, in order:
        - tm executable: resolved path and reported plugin version
        - dispatcher dir: TM_DISPATCHER_DIR (or $PWD fallback),
          whether the env was actually set, and whether the
          resolved path matches your current $PWD
        - tmux: installed? version? server running? are we inside
          a tmux session?
        - idle dir: does /tmp/claude-idle/ exist?
        - active teammates: count + names from `tm ls`
      Read-only — doesn't change any state. Use it when something
      looks off ("why is tm using the wrong path?" / "did
      /claudemux:setup actually write the env?"). Exit code is
      always 0; interpret the printed lines, not the status.
EOF
}

help_help() {
    cmd_help
}

main() {
    local sub="${1:-help}"
    shift || true

    # Help pre-scan: stop at the first non-flag positional, and stop at
    # `--prompt` (its value is data, not a flag). Both stops exist to keep
    # prompt content that happens to contain `--help` from triggering help
    # mode and silently swallowing the prompt.
    local _arg
    for _arg in "$@"; do
        case "$_arg" in
            -h|--help)
                if declare -F "help_${sub}" >/dev/null 2>&1; then
                    "help_${sub}"
                    return 0
                fi
                cmd_help
                return 0
                ;;
            --prompt|--prompt=*) break ;;  # value-bearing flag; stop scan
            -*) ;;     # other flag — keep scanning
            *) break ;; # first positional — prompt text may follow; stop
        esac
    done

    case "$sub" in
        ls)         cmd_ls "$@" ;;
        spawn)      cmd_spawn "$@" ;;
        status)     cmd_status "$@" ;;
        send)       cmd_send "$@" ;;
        resume)     cmd_resume "$@" ;;
        wait)       cmd_wait "$@" ;;
        compact)    cmd_compact "$@" ;;
        last)       cmd_last "$@" ;;
        mem)        cmd_mem "$@" ;;
        kill)       cmd_kill "$@" ;;
        reload)     cmd_reload "$@" ;;
        states)     cmd_states "$@" ;;
        poll)       cmd_poll "$@" ;;
        archive)    cmd_archive "$@" ;;
        ctx)        cmd_ctx "$@" ;;
        history)    cmd_history "$@" ;;
        doctor)     cmd_doctor "$@" ;;
        help|-h|--help)
            # `tm help <verb>` = detail for one verb (compatibility with
            # users who type it that way instead of `tm <verb> --help`).
            # Bare `tm help` / `tm --help` = top-level synopsis.
            if [[ $# -gt 0 ]] && declare -F "help_$1" >/dev/null 2>&1; then
                "help_$1"
            elif [[ $# -gt 0 ]]; then
                echo "tm: no help for unknown verb: $1" >&2
                cmd_help
                exit 1
            else
                cmd_help
            fi
            ;;
        # Removed verbs: explicit migration errors so dispatcher (or a
        # human reading old docs / memory entries) gets a clear hint
        # rather than the generic "unknown subcommand" path. Not aliases —
        # the new verbs have different semantics, so silent rerouting
        # would mislead.
        ask)
            echo "tm ask was removed in 0.3.0. Use 'tm send <repo> --prompt \"...\"' — send is now sync round-trip by default and prints the reply on stdout." >&2
            exit 2
            ;;
        wait-idle)
            echo "tm wait-idle was renamed to 'tm wait' in 0.3.0. Same semantics; the new verb also prints .last on stdout by default." >&2
            exit 2
            ;;
        wait-quiet)
            echo "tm wait-quiet was folded into the --pane-quiet flag in 0.3.0. Use 'tm wait <repo> --pane-quiet' (or 'tm send <repo> --prompt \"...\" --pane-quiet' for the send-then-wait composition)." >&2
            exit 2
            ;;
        *) echo "tm: unknown subcommand: $sub" >&2; cmd_help; exit 1 ;;
    esac
}

main "$@"
