#!/usr/bin/env bash
# Node-CLI `tm` launcher — execs the TypeScript CLI through `tsx`.
#
# Live-suite use only: stage 3 keeps the bash `bin/tm` as the user-facing PATH
# entry; this wrapper exists so the integration harness can flip
# `CLAUDEMUX_TM` at it and exercise the native verbs end to end. Production
# install of a TS-free Node CLI is stage 3c's work.
#
# `tsx` is a dev dependency declared in this package's `package.json`, so the
# launcher requires that `npm install` has populated `node_modules/`.

set -eu

HERE="$(cd "$(dirname "$0")" && pwd -P)"
TSX="$HERE/../node_modules/.bin/tsx"
CLI="$HERE/../src/cli.ts"

if [[ ! -x "$TSX" ]]; then
    echo "tm (node-cli wrapper): tsx not found at $TSX — run 'npm install' inside plugins/claudemux/core/" >&2
    exit 1
fi
if [[ ! -f "$CLI" ]]; then
    echo "tm (node-cli wrapper): CLI entry not found at $CLI" >&2
    exit 1
fi

exec "$TSX" "$CLI" "$@"
