{
  "name": "claudemux-core",
  "version": "0.0.0",
  "private": true,
  "description": "The claudemux orchestration core (the `next` line, 1.0.0-beta.0) — the verb dispatch and native verb implementations behind the `tm` CLI.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "esbuild src/main.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/cli.mjs --banner:js=\"#!/usr/bin/env node\""
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.2",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
