#!/usr/bin/env node
// Fake `codex` binary used by the supervisor tests. Accepts the same
// `app-server --listen unix://<path>` invocation the real codex binary
// understands, binds a unix-domain socket at that path, speaks a tiny
// WebSocket JSON-RPC subset (`initialize`, `thread/start`, `thread/resume`,
// `turn/start`), and then sleeps forever (until SIGTERM / SIGKILL). The
// subset is enough for CodexEngine contract tests while keeping supervisor
// lifecycle tests cheap.
//
// Optional behavior knobs via environment, for the negative-path tests:
//   CODEX_FAKE_BIND_DELAY_MS=<n>   wait <n>ms before binding the socket
//   CODEX_FAKE_EXIT_BEFORE_BIND=1  exit 7 before ever binding (spawn-fail test)
//   CODEX_FAKE_INITIALIZE_DELAY_MS=<n>
//                                  wait <n>ms before answering initialize
//   CODEX_FAKE_THREAD_READ_STATUS=<status>
//                                  answer thread/read with this status
//   CODEX_FAKE_THREAD_READ_DELAY_MS=<n>
//                                  wait <n>ms before answering thread/read
//   CODEX_FAKE_CONNECTION_LOG=<path>
//                                  append "open"/"close" connection events
//   CODEX_FAKE_RPC_LOG=<path>      append one JSON-RPC method name per request
//   CODEX_FAKE_TURN_COMPLETE_DELAY_MS=<n>
//                                  wait <n>ms before sending turn notifications
//   CODEX_FAKE_TURN_STATUS=failed  complete the turn as failed
//   CODEX_FAKE_SPAWN_CHILD=1       additionally spawn a sleeping child in the
//                                  same process group — mimics the real codex
//                                  node-wrapper → rust-binary tree the
//                                  supervisor's group-kill must reap. Without
//                                  this knob the fake is a single-pid process
//                                  group and the orphan failure mode it
//                                  guards against cannot be exercised.

import { createServer } from 'node:http'
import { spawn } from 'node:child_process'
import { appendFileSync } from 'node:fs'
import { WebSocketServer } from 'ws'

const argv = process.argv.slice(2)
if (argv[0] !== 'app-server') {
  console.error(`codex-fake: expected 'app-server', got '${argv[0]}'`)
  process.exit(2)
}

const listenIdx = argv.indexOf('--listen')
if (listenIdx < 0 || listenIdx + 1 >= argv.length) {
  console.error('codex-fake: --listen <url> required')
  process.exit(2)
}
const url = argv[listenIdx + 1]
const m = /^unix:\/\/(.+)$/.exec(url)
if (m === null) {
  console.error(`codex-fake: only unix://<path> URLs supported, got '${url}'`)
  process.exit(2)
}
const socketPath = m[1]

if (process.env.CODEX_FAKE_EXIT_BEFORE_BIND === '1') {
  process.exit(7)
}

const delay = Number.parseInt(process.env.CODEX_FAKE_BIND_DELAY_MS ?? '0', 10) || 0

function envInt(name) {
  return Number.parseInt(process.env[name] ?? '0', 10) || 0
}

function logConnection(event) {
  const file = process.env.CODEX_FAKE_CONNECTION_LOG
  if (file === undefined || file.length === 0) return
  appendFileSync(file, `${event}\n`)
}

function logRpc(method) {
  const file = process.env.CODEX_FAKE_RPC_LOG
  if (file === undefined || file.length === 0) return
  appendFileSync(file, `${method}\n`)
}

function bind() {
  const server = createServer()
  const wss = new WebSocketServer({ server })
  let threadCounter = 0
  let turnCounter = 0

  function makeThread(id, cwd = process.cwd(), ephemeral = false, status = 'idle') {
    const now = Math.floor(Date.now() / 1000)
    return {
      id,
      sessionId: `session-${id}`,
      forkedFromId: null,
      preview: '',
      ephemeral,
      modelProvider: 'fake',
      createdAt: now,
      updatedAt: now,
      status: { type: status },
      path: null,
      cwd,
      cliVersion: 'fake-codex/0.0',
      source: 'appServer',
      threadSource: null,
      agentNickname: null,
      agentRole: null,
      gitInfo: null,
      name: null,
      turns: [],
    }
  }

  function makeThreadResponse(thread) {
    return {
      thread,
      model: 'fake-model',
      modelProvider: 'fake',
      serviceTier: null,
      cwd: thread.cwd,
      runtimeWorkspaceRoots: [thread.cwd],
      instructionSources: [],
      approvalPolicy: 'never',
      approvalsReviewer: 'user',
      sandbox: { type: 'dangerFullAccess' },
      activePermissionProfile: null,
      reasoningEffort: null,
    }
  }

  wss.on('connection', (socket) => {
    logConnection('open')
    socket.on('close', () => logConnection('close'))

    function sendJson(payload, delayMs = 0) {
      const send = () => {
        if (socket.readyState === 1) socket.send(JSON.stringify(payload))
      }
      if (delayMs > 0) setTimeout(send, delayMs)
      else send()
    }

    socket.on('message', (data) => {
      const env = JSON.parse(data.toString())
      logRpc(env.method)
      const id = env.id
      const params = env.params ?? {}
      if (env.method === 'initialize') {
        sendJson({
          id,
          result: {
            userAgent: 'fake-codex/0.0',
            codexHome: '/tmp/fake-codex-home',
            platformFamily: 'unix',
            platformOs: process.platform,
          },
        }, envInt('CODEX_FAKE_INITIALIZE_DELAY_MS'))
      } else if (env.method === 'thread/start') {
        const thread = makeThread(
          `thread-${++threadCounter}`,
          params.cwd ?? process.cwd(),
          params.ephemeral === true,
        )
        sendJson({ id, result: makeThreadResponse(thread) })
      } else if (env.method === 'thread/resume') {
        const thread = makeThread(params.threadId ?? `thread-${++threadCounter}`)
        sendJson({ id, result: makeThreadResponse(thread) })
      } else if (env.method === 'thread/read' && process.env.CODEX_FAKE_THREAD_READ_STATUS !== undefined) {
        const thread = makeThread(
          params.threadId ?? `thread-${++threadCounter}`,
          params.cwd ?? process.cwd(),
          false,
          process.env.CODEX_FAKE_THREAD_READ_STATUS,
        )
        sendJson({ id, result: makeThreadResponse(thread) }, envInt('CODEX_FAKE_THREAD_READ_DELAY_MS'))
      } else if (env.method === 'turn/start') {
        const turnId = `turn-${++turnCounter}`
        const textInput = Array.isArray(params.input)
          ? (params.input.find((item) => item?.type === 'text')?.text ?? '')
          : ''
        const turnStatus = process.env.CODEX_FAKE_TURN_STATUS === 'failed' ? 'failed' : 'completed'
        const turn = {
          id: turnId,
          items: [],
          itemsView: 'notLoaded',
          status: turnStatus,
          error: turnStatus === 'failed' ? { message: 'fake failure' } : null,
          startedAt: Math.floor(Date.now() / 1000),
          completedAt: Math.floor(Date.now() / 1000),
          durationMs: 1,
        }
        const completeDelay =
          Number.parseInt(process.env.CODEX_FAKE_TURN_COMPLETE_DELAY_MS ?? '0', 10) || 0
        sendJson({ id, result: { turn } })
        setTimeout(() => {
          if (socket.readyState !== 1) return
          if (turnStatus === 'completed') {
            sendJson({
              method: 'item/completed',
              params: {
                threadId: params.threadId,
                turnId,
                completedAtMs: Date.now(),
                item: {
                  type: 'agentMessage',
                  id: `msg-${turnId}`,
                  text: `fake reply: ${textInput}`,
                  phase: null,
                  memoryCitation: null,
                },
              },
            })
          }
          sendJson({
            method: 'turn/completed',
            params: { threadId: params.threadId, turn },
          })
        }, completeDelay)
      } else {
        sendJson({ id, error: { message: `unknown method: ${env.method}` } })
      }
    })
  })
  server.listen(socketPath)
}

if (delay > 0) {
  setTimeout(bind, delay)
} else {
  bind()
}

// Optionally fork a sleeping child in the same process group so the
// supervisor's group-kill (and the SIGKILL-survives-crash test) has the
// same two-pid topology the real codex CLI exposes (node wrapper + rust
// binary). `detached: false` keeps the child in the same group as the
// parent — which is exactly what we want here: a kill-of-leader-only
// should orphan the child, and a kill-of-group should reap both.
if (process.env.CODEX_FAKE_SPAWN_CHILD === '1') {
  const child = spawn(
    process.execPath,
    ['-e', 'setInterval(() => {}, 60000)'],
    { stdio: 'ignore', detached: false },
  )
  // Node returns the ChildProcess synchronously and any spawn failure
  // arrives as an async `error` event. Without a listener, that event
  // becomes an unhandled emit and the regression test would see only
  // the leader in the group — failing with a confusing "expected
  // length >= 2" rather than the real cause. Log to stderr so the
  // log-file the supervisor wires up captures it.
  child.once('error', (e) => {
    console.error(`codex-fake: child spawn failed: ${e.message}`)
  })
}

// Stay alive until killed.
setInterval(() => {}, 60000)
process.on('SIGTERM', () => process.exit(0))
process.on('SIGINT', () => process.exit(0))
