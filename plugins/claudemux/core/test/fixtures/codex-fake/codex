#!/usr/bin/env node
// Fake `codex` binary used by the supervisor tests. Accepts the same
// `app-server --listen unix://<path>` invocation the real codex binary
// understands, binds a unix-domain socket at that path, and then sleeps
// forever (until SIGTERM / SIGKILL). The socket is non-functional —
// nothing speaks WebSocket on it — but the supervisor's responsibility
// stops at "the socket exists and the pid is alive", which is what this
// fakes.
//
// Optional behavior knobs via environment, for the negative-path tests:
//   CODEX_FAKE_BIND_DELAY_MS=<n>   wait <n>ms before binding the socket
//   CODEX_FAKE_EXIT_BEFORE_BIND=1  exit 7 before ever binding (spawn-fail test)
//   CODEX_FAKE_SPAWN_CHILD=1       additionally spawn a sleeping child in the
//                                  same process group — mimics the real codex
//                                  node-wrapper → rust-binary tree the
//                                  supervisor's group-kill must reap. Without
//                                  this knob the fake is a single-pid process
//                                  group and the orphan failure mode it
//                                  guards against cannot be exercised.

import { createServer } from 'node:net'
import { spawn } from 'node:child_process'

const argv = process.argv.slice(2)
if (argv[0] !== 'app-server') {
  console.error(`codex-fake: expected 'app-server', got '${argv[0]}'`)
  process.exit(2)
}

const listenIdx = argv.indexOf('--listen')
if (listenIdx < 0 || listenIdx + 1 >= argv.length) {
  console.error('codex-fake: --listen <url> required')
  process.exit(2)
}
const url = argv[listenIdx + 1]
const m = /^unix:\/\/(.+)$/.exec(url)
if (m === null) {
  console.error(`codex-fake: only unix://<path> URLs supported, got '${url}'`)
  process.exit(2)
}
const socketPath = m[1]

if (process.env.CODEX_FAKE_EXIT_BEFORE_BIND === '1') {
  process.exit(7)
}

const delay = Number.parseInt(process.env.CODEX_FAKE_BIND_DELAY_MS ?? '0', 10) || 0

function bind() {
  const server = createServer(() => {
    // Accept-and-ignore — we don't need to speak any protocol here.
  })
  server.listen(socketPath)
}

if (delay > 0) {
  setTimeout(bind, delay)
} else {
  bind()
}

// Optionally fork a sleeping child in the same process group so the
// supervisor's group-kill (and the SIGKILL-survives-crash test) has the
// same two-pid topology the real codex CLI exposes (node wrapper + rust
// binary). `detached: false` keeps the child in the same group as the
// parent — which is exactly what we want here: a kill-of-leader-only
// should orphan the child, and a kill-of-group should reap both.
if (process.env.CODEX_FAKE_SPAWN_CHILD === '1') {
  const child = spawn(
    process.execPath,
    ['-e', 'setInterval(() => {}, 60000)'],
    { stdio: 'ignore', detached: false },
  )
  // Node returns the ChildProcess synchronously and any spawn failure
  // arrives as an async `error` event. Without a listener, that event
  // becomes an unhandled emit and the regression test would see only
  // the leader in the group — failing with a confusing "expected
  // length >= 2" rather than the real cause. Log to stderr so the
  // log-file the supervisor wires up captures it.
  child.once('error', (e) => {
    console.error(`codex-fake: child spawn failed: ${e.message}`)
  })
}

// Stay alive until killed.
setInterval(() => {}, 60000)
process.on('SIGTERM', () => process.exit(0))
process.on('SIGINT', () => process.exit(0))
