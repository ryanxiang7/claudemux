#!/usr/bin/env bash
# test-tm-prompt-splat — regression test for the bin/tm 0.5.0 bug where
# `tm spawn --prompt` and `tm resume --prompt` exited 1 with
# "_nw[@]: unbound variable" on macOS bash 3.2 under `set -u`.
#
# Root cause: an empty bash array `_nw=()` cannot be splatted with the
# bare `"${_nw[@]}"` form under bash 3.2 + `set -u`. The fix uses the
# `${_nw[@]+"${_nw[@]}"}` idiom, which makes the splat a no-op when the
# array is empty.
#
# This test covers two layers:
#
#   1. Static. The unsafe pattern `"${_nw[@]}"` must not reappear in
#      bin/tm. The safe pattern must be present at both spawn and resume
#      callsites that hand off to cmd_send.
#
#   2. Runtime. Replicate the exact argv-assembly logic from both
#      callsites under bash 3.2 + `set -u` and confirm the resulting
#      argv matches expectations for both --no-wait and default modes
#      across the user-facing flag combinations:
#          spawn --prompt P                 (no --no-wait, no --task)
#          spawn --prompt P --no-wait
#          spawn --task T --prompt P        (no --no-wait, with --task)
#          spawn --task T                   (no --prompt — must NOT call cmd_send)
#          resume --prompt P                (same shape as spawn)
#          resume --prompt P --no-wait
#
# Run from anywhere inside the claudemux repo. Exits 0 on pass, 1 on fail.

set -euo pipefail

die() { echo "test-tm-prompt-splat: $*" >&2; exit 1; }

root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not inside a git repo"
tm="$root/plugins/claudemux/bin/tm"
[[ -f "$tm" ]] || die "$tm not found"

# ---- layer 1: static checks --------------------------------------------------

# bash -n catches plain syntax regressions (does NOT catch the empty-splat
# bug, which is a runtime error, but is cheap insurance).
bash -n "$tm" || die "bash -n failed on $tm"

# The unsafe bare splat of _nw must not reappear. The exact original-bug
# shape was `cmd_send "${_nw[@]}"` (no preceding `+` parameter
# expansion). The safe form `cmd_send ${_nw[@]+"${_nw[@]}"}` contains
# `"${_nw[@]}"` as a substring, so we anchor on the unsafe callsite
# pattern (a space, not a `+`, before the quoted splat).
if grep -nE 'cmd_send "\$\{_nw\[@\]\}"' "$tm"; then
    die 'unsafe `cmd_send "${_nw[@]}"` splat found in bin/tm — use cmd_send ${_nw[@]+"${_nw[@]}"} instead'
fi

# The safe form must be present at the two callsites we patched. We want
# exactly two occurrences: cmd_spawn and cmd_resume.
safe_count=$(grep -cE '\$\{_nw\[@\]\+"\$\{_nw\[@\]\}"\}' "$tm" || true)
[[ "$safe_count" == "2" ]] \
    || die "expected 2 safe splat sites in bin/tm (cmd_spawn + cmd_resume), found $safe_count"

# ---- layer 2: runtime simulation --------------------------------------------

# The original bug only fires under Bash 3.2 + set -u; Bash 4.4+ relaxed
# the empty-array splat rule, so on a newer shell the runtime layer can
# still pass even if the fix is reverted — only layer 1 catches that.
# Print a notice so a contributor running on brew bash 5 understands
# which line of defense is active.
if (( ${BASH_VERSINFO[0]:-0} >= 4 )); then
    echo "  note: running under bash ${BASH_VERSION%%-*} — the empty-splat \
bug does not fire on bash >= 4, so layer 2 verifies argv shape only; \
the bug-revert check is layer 1 (static grep)." >&2
fi

# Replicate cmd_spawn / cmd_resume's tail block exactly. cmd_send is
# stubbed to write its received argv to a file, one arg per line, so the
# test can assert the shape.
captured=$(mktemp)
trap 'rm -f "$captured"' EXIT

simulate() {
    # Args: no_wait has_prompt repo prompt
    # Mirrors the post-fix snippet:
    #   if (( has_prompt )); then
    #       local _nw=(); (( no_wait )) && _nw=(--no-wait)
    #       cmd_send ${_nw[@]+"${_nw[@]}"} "$repo" --prompt "$prompt"
    #   fi
    local no_wait="$1" has_prompt="$2" repo="$3" prompt="$4"
    # cmd_send stub: dump argv to $captured, one per line, with a leading
    # marker so the assert can detect "stub was not called".
    cmd_send() {
        printf 'CALLED\n'
        printf '%s\n' "$@"
    }
    : > "$captured"
    if (( has_prompt )); then
        local _nw=(); (( no_wait )) && _nw=(--no-wait)
        cmd_send ${_nw[@]+"${_nw[@]}"} "$repo" --prompt "$prompt" > "$captured"
    fi
}

assert_argv() {
    local label="$1"; shift
    local expected=("$@")
    local got=()
    if [[ -s "$captured" ]]; then
        local first
        IFS= read -r first < "$captured"
        if [[ "$first" != "CALLED" ]]; then
            die "[$label] expected stub marker CALLED, got '$first'"
        fi
        # Read remaining lines into the got array.
        while IFS= read -r line; do
            got+=("$line")
        done < <(tail -n +2 "$captured")
    fi
    local n_expected="${#expected[@]}" n_got="${#got[@]}"
    if [[ "$n_got" != "$n_expected" ]]; then
        die "[$label] expected $n_expected args, got $n_got: ${got[*]:-}"
    fi
    local i
    for ((i = 0; i < n_expected; i++)); do
        if [[ "${got[i]}" != "${expected[i]}" ]]; then
            die "[$label] argv[$i] expected '${expected[i]}', got '${got[i]}'"
        fi
    done
    echo "  ok: $label"
}

assert_no_call() {
    local label="$1"
    if [[ -s "$captured" ]]; then
        die "[$label] expected cmd_send to NOT be called, but got: $(cat "$captured")"
    fi
    echo "  ok: $label"
}

# Case A: spawn --prompt P  (no --no-wait)
simulate 0 1 myrepo "hello world"
assert_argv "spawn --prompt P" myrepo --prompt "hello world"

# Case B: spawn --prompt P --no-wait
simulate 1 1 myrepo "hello world"
assert_argv "spawn --prompt P --no-wait" --no-wait myrepo --prompt "hello world"

# Case C: spawn --task T --prompt P (task is upstream of this snippet; the
# tail block only sees has_prompt+no_wait, so this argv shape equals A)
simulate 0 1 myrepo "multi-line\nprompt body with 'quotes' and \$dollars"
assert_argv "spawn --task T --prompt P" myrepo --prompt "multi-line\nprompt body with 'quotes' and \$dollars"

# Case D: spawn --task T (no --prompt) — cmd_send must NOT be called
simulate 0 0 myrepo ""
assert_no_call "spawn --task T (no --prompt)"

# Case E: resume --prompt P (same code path, same expectations)
simulate 0 1 otherrepo "resume body"
assert_argv "resume --prompt P" otherrepo --prompt "resume body"

# Case F: resume --prompt P --no-wait
simulate 1 1 otherrepo "resume body"
assert_argv "resume --prompt P --no-wait" --no-wait otherrepo --prompt "resume body"

echo "all checks passed"
