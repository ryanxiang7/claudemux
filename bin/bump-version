#!/usr/bin/env bash
# bump-version <plugin> <patch|minor|major> — bump the "version" field in a
# plugin's manifest. <plugin> is a directory name under plugins/. Run from
# anywhere inside the claudemux git repo.
#
# Echoes "<plugin>: <old> -> <new>" on success.
#
# Pairs with .githooks/pre-commit, which rejects a commit that touches a
# plugin's feature-class paths without bumping that plugin's own version.

set -euo pipefail

die() { echo "bump-version: $*" >&2; exit 1; }

plugin="${1:-}"
level="${2:-}"

[[ -n "$plugin" ]] || die "usage: bin/bump-version <plugin> <patch|minor|major>"
case "$level" in
    patch|minor|major) ;;
    "") die "usage: bin/bump-version <plugin> <patch|minor|major>" ;;
    *)  die "invalid level '$level' — must be patch, minor, or major" ;;
esac

root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not inside a git repo"
manifest="$root/plugins/$plugin/.claude-plugin/plugin.json"
if [[ ! -f "$manifest" ]]; then
    available=""
    for dir in "$root"/plugins/*/; do
        [[ -d "$dir" ]] || continue
        name=${dir%/}
        available+="${name##*/} "
    done
    die "unknown plugin '$plugin' — no manifest at" \
        "plugins/$plugin/.claude-plugin/plugin.json (available: ${available:-none})"
fi

old=$(jq -r '.version' "$manifest")
[[ "$old" =~ ^([0-9]+)\.([0-9]+)\.([0-9]+)$ ]] \
    || die "current version '$old' is not semver MAJOR.MINOR.PATCH"
M="${BASH_REMATCH[1]}"; m="${BASH_REMATCH[2]}"; p="${BASH_REMATCH[3]}"

case "$level" in
    patch) p=$((p + 1)) ;;
    minor) m=$((m + 1)); p=0 ;;
    major) M=$((M + 1)); m=0; p=0 ;;
esac
new="${M}.${m}.${p}"

tmp=$(mktemp)
jq --arg v "$new" '.version = $v' "$manifest" > "$tmp"
mv "$tmp" "$manifest"

echo "$plugin: $old -> $new"
