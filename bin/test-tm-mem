#!/usr/bin/env bash
# test-tm-mem — regression test for `tm mem <repo>`.
#
# Covers the four observable outcomes the dispatcher relies on:
#
#   1. Missing-arg     usage line on stderr, exit 1, empty stdout.
#   2. Unknown repo    die_repo_not_found, exit 1, empty stdout.
#   3. Memory present  MEMORY.md content on stdout byte-for-byte,
#                      exit 0.
#   4. Memory absent   one-line "no auto-memory recorded for X" on
#                      stderr, exit 0, empty stdout.
#
# Also locks in the path-encoding contract: the resolved MEMORY.md
# path is exactly $HOME/.claude/projects/<encoded>/memory/MEMORY.md
# where <encoded> = the repo's physical cwd with every `/` and `.`
# replaced by `-`. The stderr notice in case (4) prints the looked-at
# path, so we assert against that string.
#
# Run from anywhere inside the claudemux repo. Exits 0 on pass, 1 on
# fail. Uses a sandboxed $HOME so it cannot read or write the
# developer's real ~/.claude/projects.

set -euo pipefail

die() { echo "test-tm-mem: $*" >&2; exit 1; }

root=$(git rev-parse --show-toplevel 2>/dev/null) || die "not inside a git repo"
tm="$root/plugins/claudemux/bin/tm"
[[ -f "$tm" ]] || die "$tm not found"

bash -n "$tm" || die "bash -n failed on $tm"

# Sandbox: isolated HOME so we never touch the developer's real
# ~/.claude/projects. The dispatcher dir lives inside the sandbox so
# the encoded path is fully predictable.
sandbox=$(mktemp -d)
trap 'rm -rf "$sandbox"' EXIT

export HOME="$sandbox/home"
mkdir -p "$HOME"

disp="$sandbox/disp"
mkdir -p "$disp/repo-with-mem" "$disp/repo-without-mem"
export TM_DISPATCHER_DIR="$disp"

# Derive the encoded path the way `tm mem` does, so the test fails
# loudly if either the test or the script drifts from the Claude Code
# encoding convention.
phys_with=$(cd "$disp/repo-with-mem" && pwd -P)
encoded_with=$(printf '%s' "$phys_with" | tr './' '-')
mem_dir_with="$HOME/.claude/projects/$encoded_with/memory"
mkdir -p "$mem_dir_with"
mem_file_with="$mem_dir_with/MEMORY.md"

phys_without=$(cd "$disp/repo-without-mem" && pwd -P)
encoded_without=$(printf '%s' "$phys_without" | tr './' '-')
mem_file_without="$HOME/.claude/projects/$encoded_without/memory/MEMORY.md"

# Realistic content: a small MEMORY.md index with a couple of pointer
# lines (mirrors what the auto-memory writer produces). We byte-compare
# against the stdout so the test catches any accidental rewrap/trim in
# cmd_mem.
cat > "$mem_file_with" <<'MEM'
- [In-progress: foo refactor](project_foo.md) — branch feat/foo, owner alice
- [TODO: bar guard sweep](todo_bar.md) — 7 sites pending
MEM

# --- case 1: missing arg ----------------------------------------------------
stdout=$("$tm" mem 2>/dev/null || true)
status=0; "$tm" mem >/dev/null 2>/dev/null || status=$?
[[ "$status" == "1" ]] || die "case 1 (no arg): expected exit 1, got $status"
[[ -z "$stdout" ]]     || die "case 1 (no arg): expected empty stdout, got: $stdout"

stderr=$("$tm" mem 2>&1 1>/dev/null || true)
[[ "$stderr" == *"usage: tm mem <repo>"* ]] \
    || die "case 1 (no arg): stderr did not contain usage hint: $stderr"

# --- case 2: unknown repo ---------------------------------------------------
stdout=$("$tm" mem nonexistent-repo 2>/dev/null || true)
status=0; "$tm" mem nonexistent-repo >/dev/null 2>/dev/null || status=$?
[[ "$status" == "1" ]] || die "case 2 (unknown repo): expected exit 1, got $status"
[[ -z "$stdout" ]]     || die "case 2 (unknown repo): expected empty stdout, got: $stdout"

stderr=$("$tm" mem nonexistent-repo 2>&1 1>/dev/null || true)
[[ "$stderr" == *"repo not found at $disp/nonexistent-repo"* ]] \
    || die "case 2 (unknown repo): stderr did not match expected die_repo_not_found shape: $stderr"

# --- case 3: memory present -------------------------------------------------
stdout=$("$tm" mem repo-with-mem 2>/dev/null)
status=0; "$tm" mem repo-with-mem >/dev/null 2>/dev/null || status=$?
[[ "$status" == "0" ]] || die "case 3 (memory present): expected exit 0, got $status"

expected_content=$(cat "$mem_file_with")
[[ "$stdout" == "$expected_content" ]] \
    || die "case 3 (memory present): stdout did not match MEMORY.md byte-for-byte.
        Expected:
$expected_content
        Got:
$stdout"

# --- case 4: memory absent --------------------------------------------------
stdout=$("$tm" mem repo-without-mem 2>/dev/null)
status=0; "$tm" mem repo-without-mem >/dev/null 2>/dev/null || status=$?
[[ "$status" == "0" ]] || die "case 4 (memory absent): expected exit 0, got $status"
[[ -z "$stdout" ]]     || die "case 4 (memory absent): expected empty stdout, got: $stdout"

stderr=$("$tm" mem repo-without-mem 2>&1 1>/dev/null)
[[ "$stderr" == *"no auto-memory recorded for repo-without-mem"* ]] \
    || die "case 4 (memory absent): stderr did not contain the no-auto-memory notice: $stderr"

# Path-encoding lock-in: the stderr notice prints the resolved path,
# so a regression in the encoding rule (e.g. dropping the `.` → `-`
# replacement) would change that string.
[[ "$stderr" == *"$mem_file_without"* ]] \
    || die "case 4 (memory absent): stderr did not name the expected resolved path '$mem_file_without': $stderr"

echo "test-tm-mem: OK"
